---
import '../styles/global.css'
import '../styles/components.css'
import Header from '../components/global/Header.astro'
import AnnouncementBanner from '../components/global/AnnouncementBanner.astro'
import Footer from '../components/global/Footer.astro'
import SearchModal from '../components/global/SearchModal.astro'
import FeedbackFab from '../components/global/FeedbackFab.astro'

interface Props {
  title: string
  description?: string
  image?: string
  ogType?: 'website' | 'article'
  noIndex?: boolean
  jsonLd?: Record<string, any>[]
  preloadImages?: string[]
}

const {
  title,
  description = 'Claude Code from beginner to power user. Exhaustive documentation, production-ready templates, agentic workflow guides, quiz, and cheatsheet for daily use.',
  image = '/og-image.png',
  ogType = 'website',
  noIndex = false,
  jsonLd,
  preloadImages = [],
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const ogImageURL = new URL(image, Astro.site)
const gaId = 'G-WH1C8CM79E'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />

    {preloadImages.map((imgSrc) => (
      <link rel="preload" as="image" href={imgSrc} />
    ))}

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Florian BRUNIAUX" />
    <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1'} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Claude Code Ultimate Guide" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@FlorianBruniaux" />
    <meta name="twitter:creator" content="@FlorianBruniaux" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Claude Code CLI Releases" href="/rss.xml" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://img.shields.io" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />

    <!-- Anti-FOUC: dark mode default for developer audience -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        var theme = stored || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <!-- JSON-LD: WebSite + BreadcrumbList (@graph) -->
    <script type="application/ld+json" set:html={JSON.stringify((() => {
      const pathSegments = Astro.url.pathname.split('/').filter(Boolean)
      const breadcrumbs = [
        { "@type": "ListItem", position: 1, name: "Home", item: String(Astro.site) }
      ]
      let currentPath = String(Astro.site).replace(/\/$/, '')
      pathSegments.forEach((segment, index) => {
        currentPath += `/${segment}`
        const name = segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' ')
        breadcrumbs.push({
          "@type": "ListItem",
          position: index + 2,
          name,
          item: currentPath,
        })
      })

      return {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://cc.bruniaux.com/#website",
            name: "Claude Code Ultimate Guide",
            url: Astro.site,
            description: "Free, open-source guide for Claude Code (Anthropic CLI)",
            author: {
              "@type": "Person",
              name: "Florian BRUNIAUX",
              url: "https://github.com/FlorianBruniaux",
              sameAs: [
                "https://github.com/FlorianBruniaux",
                "https://www.linkedin.com/in/florian-bruniaux-43408b83/",
              ],
            },
            publisher: {
              "@type": "Organization",
              name: "Méthode Aristote",
              url: "https://methode-aristote.fr",
            },
            potentialAction: {
              "@type": "SearchAction",
              target: "https://cc.bruniaux.com/?q={search_term_string}",
              "query-input": "required name=search_term_string",
            },
            speakable: {
              "@type": "SpeakableSpecification",
              cssSelector: ["h1", ".hero-description", ".faq-answer", ".golden-rule-title"],
            },
          },
          {
            "@type": "BreadcrumbList",
            itemListElement: breadcrumbs,
          },
        ],
      }
    })())} />

    <!-- Additional JSON-LD schemas (page-specific) -->
    {jsonLd?.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", ...schema })} />
    ))}

    <!-- Google Analytics 4 via Partytown -->
    <script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
    <script type="text/partytown" define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class="pt-14">
      <AnnouncementBanner />
      <slot />
    </main>
    <Footer />
    <SearchModal />
    <FeedbackFab />
  </body>
</html>

<style is:global>
  /* ── Expressive-code copy button: always visible (not just on hover) ── */
  .expressive-code .copy button {
    opacity: 1 !important;
  }
  .expressive-code .copy button:not(:hover) {
    background: transparent !important;
    border-color: rgba(255,255,255,0.15) !important;
    color: var(--text-muted, #888) !important;
  }
  .expressive-code .copy button:hover {
    opacity: 1 !important;
    border-color: var(--accent, #f97316) !important;
    color: var(--accent, #f97316) !important;
    background: color-mix(in srgb, var(--accent, #f97316) 8%, transparent) !important;
  }

  /* ── Copy button on non-expressive-code <pre> blocks ── */
  .code-copy-wrapper {
    position: relative;
  }
  .code-copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.55rem;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 0.3rem;
    color: var(--text-muted, #666);
    font-size: 0.72rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    z-index: 2;
    white-space: nowrap;
    line-height: 1.4;
  }
  .code-copy-btn:hover {
    color: var(--accent, #f97316);
    border-color: var(--accent, #f97316);
    background: color-mix(in srgb, var(--accent, #f97316) 8%, transparent);
  }
  .code-copy-btn.copied {
    color: #22c55e;
    border-color: #22c55e;
    background: color-mix(in srgb, #22c55e 8%, transparent);
  }
  /* Ensure pre has room for the button */
  .code-copy-wrapper > pre {
    padding-top: 2.2rem !important;
  }
</style>

<script>
  function initCopyButtons() {
    // Skip <pre> already inside expressive-code (Starlight) or already wrapped
    const pres = document.querySelectorAll('pre:not(.expressive-code pre):not(.code-copy-wrapper pre)')
    pres.forEach((pre) => {
      if (pre.closest('.expressive-code') || pre.closest('.code-copy-wrapper')) return

      const wrapper = document.createElement('div')
      wrapper.className = 'code-copy-wrapper'

      const btn = document.createElement('button')
      btn.className = 'code-copy-btn'
      btn.setAttribute('aria-label', 'Copy code')
      btn.textContent = 'Copy'

      btn.addEventListener('click', async (e) => {
        e.stopPropagation()
        const text = pre.innerText ?? pre.textContent ?? ''
        try {
          await navigator.clipboard.writeText(text)
          btn.textContent = 'Copied!'
          btn.classList.add('copied')
          setTimeout(() => {
            btn.textContent = 'Copy'
            btn.classList.remove('copied')
          }, 2000)
        } catch {
          // Fallback for older browsers
          const ta = document.createElement('textarea')
          ta.value = text
          ta.style.cssText = 'position:fixed;opacity:0;pointer-events:none'
          document.body.appendChild(ta)
          ta.select()
          try { document.execCommand('copy') } catch {}
          document.body.removeChild(ta)
          btn.textContent = 'Copied!'
          btn.classList.add('copied')
          setTimeout(() => {
            btn.textContent = 'Copy'
            btn.classList.remove('copied')
          }, 2000)
        }
      })

      pre.parentNode?.insertBefore(wrapper, pre)
      wrapper.appendChild(btn)
      wrapper.appendChild(pre)
    })
  }

  // Run on initial load
  document.addEventListener('DOMContentLoaded', initCopyButtons)
  // Also run immediately in case DOMContentLoaded already fired
  if (document.readyState !== 'loading') initCopyButtons()
</script>
