---
/**
 * AnnouncementBanner
 * Dismissible strip under the nav to surface major new content.
 * Dismissed state stored in localStorage so it stays hidden on reload.
 *
 * Update `BANNER_ID` whenever you change the message — this resets
 * the dismissed state for all visitors.
 */

// Increment this ID whenever the banner content changes
const BANNER_ID = 'banner-rss-2026-03'
---

<div id="announcement-banner" class="ann-banner" data-banner-id={BANNER_ID} aria-label="Announcement">
  <div class="ann-inner">
    <div class="ann-content">
      <span class="ann-badge">NEW</span>
      <span class="ann-text">
        <a href="/whitepapers/" class="ann-link">11 Ebooks — 472 pages, FR + EN, PDF + EPUB →</a>
        <span class="ann-sep" aria-hidden="true">·</span>
        <a href="/cheatsheets/" class="ann-link">57 Recap Cards →</a>
        <span class="ann-sep" aria-hidden="true">·</span>
        <a href="/rss.xml" class="ann-link ann-rss">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:inline;vertical-align:-1px;margin-right:3px;"><path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/></svg>
          RSS feed →
        </a>
      </span>
    </div>
    <button
      id="ann-close"
      class="ann-close"
      aria-label="Dismiss announcement"
      type="button"
    >×</button>
  </div>
</div>

<script>
  const BANNER_ID = document.getElementById('announcement-banner')?.dataset.bannerId ?? ''
  const STORAGE_KEY = `ann_dismissed_${BANNER_ID}`
  const banner = document.getElementById('announcement-banner')

  // Hide immediately if already dismissed
  if (localStorage.getItem(STORAGE_KEY) === '1') {
    banner?.remove()
  }

  document.getElementById('ann-close')?.addEventListener('click', () => {
    localStorage.setItem(STORAGE_KEY, '1')
    banner?.remove()
  })
</script>

<style>
.ann-banner {
  background: var(--bg-secondary);
  border-bottom: 1px solid color-mix(in srgb, var(--accent) 40%, var(--border));
  border-top: 2px solid var(--accent);
  font-size: 0.875rem;
  line-height: 1.4;
}

.ann-inner {
  max-width: var(--max-width, 1200px);
  margin: 0 auto;
  padding: 0.5rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.ann-content {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex: 1;
  min-width: 0;
}

.ann-badge {
  flex-shrink: 0;
  display: inline-block;
  padding: 0.15rem 0.5rem;
  background: var(--accent);
  color: #fff;
  font-size: 0.7rem;
  font-weight: 700;
  font-family: var(--font-mono);
  letter-spacing: 0.08em;
  border-radius: 3px;
}

.ann-text {
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.ann-link {
  color: var(--accent);
  font-weight: 500;
  text-decoration: none;
  white-space: nowrap;
}

.ann-link:hover {
  text-decoration: underline;
}

.ann-sep {
  color: var(--border);
  flex-shrink: 0;
  user-select: none;
}

.ann-close {
  flex-shrink: 0;
  background: none;
  border: none;
  color: var(--text-secondary);
  font-size: 1.1rem;
  cursor: pointer;
  padding: 0.25rem 0.375rem;
  line-height: 1;
  border-radius: 3px;
  opacity: 0.6;
  transition: opacity 0.15s;
}

.ann-close:hover {
  opacity: 1;
  background: var(--bg-tertiary);
}

@media (max-width: 640px) {
  .ann-text {
    white-space: normal;
  }

  .ann-inner {
    padding: 0.5rem 1rem;
  }
}
</style>
