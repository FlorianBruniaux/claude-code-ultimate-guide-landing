---
import Default from '@astrojs/starlight/components/Head.astro'

const { entry } = Astro.props
const url = Astro.url.pathname
const isWorkflow = url.includes('/workflows/')

const pageUrl = `https://cc.bruniaux.com${url}`
const title = entry?.data?.title ?? ''
const description = entry?.data?.description ?? ''

const schema = isWorkflow
  ? {
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": title,
      "description": description,
      "url": pageUrl,
      "author": { "@type": "Person", "@id": "https://cc.bruniaux.com/#author", "name": "Florian BRUNIAUX" },
      "publisher": { "@type": "Organization", "@id": "https://cc.bruniaux.com/#organization", "name": "Claude Code Ultimate Guide", "url": "https://cc.bruniaux.com" },
      "inLanguage": "en",
    }
  : {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      "headline": title,
      "description": description,
      "url": pageUrl,
      "datePublished": "2026-01-17",
      "dateModified": "2026-06-25",
      "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
      "author": { "@type": "Person", "@id": "https://cc.bruniaux.com/#author", "name": "Florian BRUNIAUX" },
      "publisher": { "@type": "Organization", "@id": "https://cc.bruniaux.com/#organization", "name": "Claude Code Ultimate Guide", "url": "https://cc.bruniaux.com" },
      "inLanguage": "en",
    }
---
<Default {...Astro.props} />
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
