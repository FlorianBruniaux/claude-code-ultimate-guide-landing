---
interface BlogPost {
  title: string
  link: string
  date: string
}

let posts: BlogPost[] = []
let fetchFailed = false

try {
  const res = await fetch('https://www.florian.bruniaux.com/rss.xml', {
    headers: { 'User-Agent': 'cc.bruniaux.com build bot' },
  })
  if (!res.ok) throw new Error(`RSS fetch returned ${res.status}`)
  const xml = await res.text()

  const itemPattern = /<item>([\s\S]*?)<\/item>/g
  let match
  const rawItems: BlogPost[] = []

  while ((match = itemPattern.exec(xml)) !== null) {
    const block = match[1]

    const titleMatch = block.match(/<title><!\[CDATA\[([\s\S]*?)\]\]><\/title>/) ||
                       block.match(/<title>([\s\S]*?)<\/title>/)
    const linkMatch = block.match(/<link>([\s\S]*?)<\/link>/)
    const dateMatch = block.match(/<pubDate>([\s\S]*?)<\/pubDate>/)

    if (!titleMatch || !linkMatch) continue

    let title = titleMatch[1].trim().replace(/^\d+\/\d+\s+·\s+/, '')
    title = title
      .replace(/&amp;/g, '&')
      .replace(/&lt;/g, '<')
      .replace(/&gt;/g, '>')
      .replace(/&quot;/g, '"')
      .replace(/&apos;/g, "'")
      .replace(/&#39;/g, "'")

    const link = linkMatch[1].trim()

    let date = ''
    if (dateMatch) {
      const d = new Date(dateMatch[1].trim())
      if (!isNaN(d.getTime())) {
        date = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
      }
    }

    rawItems.push({ title, link, date })
  }

  posts = rawItems.slice(0, 3)
  if (posts.length === 0) fetchFailed = true
} catch {
  fetchFailed = true
}
---

{fetchFailed ? (
  <div class="blog-posts blog-posts--fallback">
    <a href="https://www.florian.bruniaux.com/blog/" target="_blank" rel="noopener noreferrer" class="blog-fallback-link">
      Read the blog ↗
    </a>
  </div>
) : (
  <div class="blog-posts">
    <div class="blog-posts-header">
      <a href="https://www.florian.bruniaux.com/blog/" target="_blank" rel="noopener noreferrer" class="blog-posts-heading">
        From the blog ↗
      </a>
    </div>
    <ul class="blog-posts-list">
      {posts.map((post) => (
        <li class="blog-post-item">
          <span class="blog-post-arrow" aria-hidden="true">→</span>
          <a href={post.link} target="_blank" rel="noopener noreferrer" class="blog-post-title">
            {post.title}
          </a>
          {post.date && <span class="blog-post-date">{post.date}</span>}
        </li>
      ))}
    </ul>
    <a href="https://www.florian.bruniaux.com/blog/" target="_blank" rel="noopener noreferrer" class="blog-posts-viewall">
      View all posts →
    </a>
  </div>
)}

