---
interface Guide {
  title: string
  link: string
  date: string
}

let guides: Guide[] = []
let fetchFailed = false

try {
  const res = await fetch('https://www.florian.bruniaux.com/guides/', {
    headers: { 'User-Agent': 'cc.bruniaux.com build bot' },
  })
  if (!res.ok) throw new Error(`Guides fetch returned ${res.status}`)
  const html = await res.text()

  const scriptPattern = /<script type="application\/ld\+json">([\s\S]*?)<\/script>/g
  let match
  let itemListElement: any[] = []

  while ((match = scriptPattern.exec(html)) !== null) {
    try {
      const json = JSON.parse(match[1])
      if (json['@type'] === 'CollectionPage' && json.mainEntity?.itemListElement) {
        itemListElement = json.mainEntity.itemListElement
        break
      }
    } catch {
      continue
    }
  }

  guides = itemListElement
    .map((entry) => {
      const item = entry.item
      if (!item?.name || !item?.url) return null
      let date = ''
      if (item.datePublished) {
        const d = new Date(item.datePublished)
        if (!isNaN(d.getTime())) {
          date = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
        }
      }
      return { title: item.name, link: item.url, date }
    })
    .filter((g): g is Guide => g !== null)
    .slice(0, 3)

  if (guides.length === 0) fetchFailed = true
} catch {
  fetchFailed = true
}
---

{fetchFailed ? (
  <div class="guides-posts guides-posts--fallback">
    <a href="https://www.florian.bruniaux.com/guides/" target="_blank" rel="noopener noreferrer" class="guides-fallback-link">
      Read the quick guides ↗
    </a>
  </div>
) : (
  <div class="guides-posts">
    <div class="guides-posts-header">
      <a href="https://www.florian.bruniaux.com/guides/" target="_blank" rel="noopener noreferrer" class="guides-posts-heading">
        Quick guides ↗
      </a>
    </div>
    <ul class="guides-posts-list">
      {guides.map((guide) => (
        <li class="guides-post-item">
          <span class="guides-post-arrow" aria-hidden="true">→</span>
          <a href={guide.link} target="_blank" rel="noopener noreferrer" class="guides-post-title">
            {guide.title}
          </a>
          {guide.date && <span class="guides-post-date">{guide.date}</span>}
        </li>
      ))}
    </ul>
    <a href="https://www.florian.bruniaux.com/guides/" target="_blank" rel="noopener noreferrer" class="guides-posts-viewall">
      View all guides →
    </a>
  </div>
)}

<style>
.guides-posts {
  padding-left: 0.9rem;
  border-left: 2px solid var(--border);
}

.guides-posts--fallback {
  display: flex;
  align-items: center;
