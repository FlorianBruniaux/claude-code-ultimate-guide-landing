---
const whitepapers = [
  { id: 'WP00', title: 'Introduction & Fundamentals' },
  { id: 'WP01', title: 'Effective Prompts' },
  { id: 'WP02', title: 'Customization & Configuration' },
  { id: 'WP03', title: 'Security in Production' },
  { id: 'WP04', title: 'Internal Architecture' },
  { id: 'WP05', title: 'Team Adoption' },
  { id: 'WP06', title: 'Privacy & Compliance' },
  { id: 'WP07', title: 'Condensed Reference Guide' },
  { id: 'WP08', title: 'Agent Teams & Sub-Agents' },
  { id: 'WP09', title: 'Learning with AI — UVAL' },
  { id: 'WP10', title: 'AI Budget & ROI' },
]
---

<section class="section wp-section" id="whitepapers">
  <div class="container">
    <h2 class="section-title">Whitepapers & Recap Cards</h2>
    <p class="section-subtitle">
      11 whitepapers · 472 pages · PDF + EPUB · FR + EN — from foundations to AI budget justification for decision-makers
    </p>

    <div class="wp-layout">
      <!-- Whitepapers list -->
      <div class="wp-list-wrapper">
        <div class="wp-list-header">
          <span class="wp-count-badge">11 whitepapers</span>
          <span class="wp-lang-pill">FR + EN</span>
          <span class="wp-lang-pill">PDF + EPUB</span>
        </div>
        <ul class="wp-list">
          {whitepapers.map((wp) => (
            <li class="wp-item">
              <span class="wp-id">{wp.id}</span>
              <span class="wp-title">{wp.title}</span>
            </li>
          ))}
        </ul>
        <a href="/whitepapers/" class="wp-browse-cta">Browse all ebooks &rarr;</a>
      </div>

      <!-- Recap cards -->
      <div class="recap-card">
        <div class="recap-header">
          <span class="recap-badge">57 CARDS</span>
          <span class="recap-label">Recap Cards</span>
          <span class="wp-lang-pill">FR · EN coming</span>
        </div>
        <p class="recap-desc">
          57 A4 recap cards — 1 page per concept, 3 series covering every aspect of Claude Code. Printable, ready to use.
        </p>
        <ul class="recap-features">
          <li>Technique (22 cards) — Commands, config, MCP, sandbox</li>
          <li>Méthodologie (22 cards) — Workflows, agents, hooks, CI/CD</li>
          <li>Conception (13 cards) — Mental models, security, cost</li>
          <li>Bold Guy palette — 1-page A4 strict, high-quality PDF</li>
        </ul>
        <a href="/cheatsheets/" class="wp-browse-cta">Browse all recap cards &rarr;</a>
      </div>
    </div>
  </div>
</section>

<style>
.wp-section {
  background-color: var(--bg-primary);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.wp-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-2xl);
  align-items: start;
}

/* Whitepapers list */
.wp-list-wrapper {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-left: 3px solid var(--accent);
  border-radius: var(--border-radius-lg);
  padding: var(--space-xl);
}

.wp-list-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
}

.wp-count-badge {
  background: var(--accent);
  color: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  letter-spacing: 0.02em;
}

.wp-lang-pill {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--text-secondary);
  border: 1px solid var(--border);
  padding: 0.15rem 0.5rem;
  border-radius: 999px;
  font-family: var(--font-mono);
}

.wp-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.wp-item {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  padding: 0.5rem 0;
  border-bottom: 1px solid var(--border);
}

.wp-item:last-child {
  border-bottom: none;
}

.wp-id {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--accent);
  min-width: 3.5rem;
  flex-shrink: 0;
}

.wp-title {
  font-size: 0.9rem;
  color: var(--text-primary);
  line-height: 1.4;
}

/* Recap cards */
.recap-card {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--border-radius-lg);
  border-left: 3px solid var(--border);
  padding: var(--space-xl);
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.recap-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.recap-badge {
  background: var(--text-secondary);
  color: #fff;
  font-size: 0.68rem;
  font-weight: 800;
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.recap-label {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
}

.recap-desc {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.6;
  margin: 0;
}

.recap-features {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.recap-features li {
  font-size: 0.875rem;
  color: var(--text-secondary);
  padding-left: 1.25rem;
  position: relative;
  line-height: 1.4;
}

.recap-features li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--text-secondary);
  font-size: 0.75rem;
  top: 0.1em;
}

.wp-browse-cta {
  display: inline-block;
  margin-top: var(--space-lg);
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  transition: color 0.15s;
}
.wp-browse-cta:hover { color: var(--accent-hover, var(--accent)); text-decoration: underline; }

/* Responsive */
@media (max-width: 900px) {
  .wp-layout {
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }
}

@media (max-width: 640px) {
  .wp-list-wrapper,
  .recap-card {
    padding: var(--space-lg);
  }

  .wp-id {
    min-width: 3rem;
    font-size: 0.68rem;
  }

  .wp-title {
    font-size: 0.85rem;
  }
}
</style>
