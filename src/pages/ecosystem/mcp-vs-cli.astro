      flex-direction: column;
      gap: var(--space-lg);
      max-width: 760px;
    }

    .practitioner-quote {
      margin: 0;
      padding: var(--space-lg) var(--space-xl);
      border-left: 4px solid var(--accent-tertiary, #3b82f6);
      background: var(--surface-elevated);
      border-radius: 0 var(--border-radius-lg) var(--border-radius-lg) 0;
    }

    .practitioner-quote p {
      margin: 0 0 var(--space-sm);
      font-style: italic;
      color: var(--text-primary);
      line-height: 1.65;
    }

    .quote-tag {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-muted);
      font-family: var(--font-mono);
      text-transform: lowercase;
    }

    /* ── SITUATIONS TABLE ─────────────────────────────────────────────────── */
    .situations-groups {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    details {
      border: 1px solid var(--border);
      border-radius: var(--border-radius-lg);
      background: var(--surface-elevated);
      overflow: hidden;
    }

    summary {
      padding: var(--space-md) var(--space-xl);
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      user-select: none;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      color: var(--text-primary);
      transition: background 0.15s ease;
    }

    summary::-webkit-details-marker { display: none; }

    summary::after {
      content: '\25B2';
      font-size: 0.65rem;
      color: var(--text-muted);
      transition: transform 0.2s ease;
    }

    details:not([open]) summary::after {
      transform: rotate(180deg);
    }

    summary:hover { background: var(--bg-tertiary); }

    .situations-table-wrap {
      overflow-x: auto;
    }

    .situations-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }

    .situations-table th,
    .situations-table td {
      padding: var(--space-sm) var(--space-xl);
      text-align: left;
      border-top: 1px solid var(--border);
    }

    .situations-table th {
      background: var(--bg-tertiary);
      font-weight: 600;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-muted);
    }

    .situations-table td:first-child {
      font-weight: 500;
      color: var(--text-primary);
      width: 36%;
    }

    .situations-table td:last-child {
      color: var(--text-secondary);
      font-size: 0.85rem;
    }

    .situations-table tbody tr:hover { background: var(--bg-tertiary); }

    .badge-inline {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: var(--border-radius);
      font-size: 0.72rem;
      font-weight: 700;
      font-family: var(--font-mono);
      white-space: nowrap;
    }

    /* ── TOOLING ROWS ─────────────────────────────────────────────────────── */
    .tooling-rows {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    .tooling-row {
      display: grid;
      grid-template-columns: 180px 1fr auto;
      align-items: center;
      gap: var(--space-lg);
      padding: var(--space-lg) var(--space-xl);
      background: var(--surface-elevated);
      border: 1px solid var(--border);
      border-radius: var(--border-radius-lg);
    }

    .tooling-name {
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      flex-wrap: wrap;
    }

    .tooling-desc {
      font-size: 0.875rem;
      color: var(--text-secondary);
      line-height: 1.5;
    }

    .tooling-link {
      font-size: 0.8rem;
      color: var(--accent);
      text-decoration: none;
      white-space: nowrap;
    }

    .tooling-link:hover { text-decoration: underline; }

    .maturity-badge {
      display: inline-flex;
      padding: 2px 7px;
      border-radius: var(--border-radius);
      font-size: 0.68rem;
      font-weight: 700;
      font-family: var(--font-mono);
      text-transform: uppercase;
    }

    .maturity-stable { background: rgba(16, 185, 129, 0.15); color: #10b981; }
    .maturity-ready { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
    .maturity-watch { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }

    /* ── CTA ──────────────────────────────────────────────────────────────── */
    .cta-block {
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
    }

    .cta-block h2 {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: var(--space-md);
    }

    .cta-block p {
      color: var(--text-secondary);
      margin-bottom: var(--space-xl);
      line-height: 1.6;
    }

    .cta-block-btns {
      display: flex;
      justify-content: center;
      gap: var(--space-md);
      flex-wrap: wrap;
      margin-bottom: var(--space-lg);
    }

    .cta-back {
      font-size: 0.875rem;
      margin-bottom: 0;
    }

    .cta-back a {
      color: var(--text-muted);
      text-decoration: none;
    }

    .cta-back a:hover { color: var(--accent); }

    /* ── RESPONSIVE ───────────────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .decision-card {
        flex-direction: column;
        gap: var(--space-md);
      }

      .decision-branches {
        gap: var(--space-xs);
      }

      .tooling-row {
        grid-template-columns: 1fr;
        gap: var(--space-sm);
      }

      .tldr-callout {
        padding: var(--space-lg);
      }
    }

    @media (max-width: 480px) {
      /* Guidance table: stacked cards */
      .situations-table thead { display: none; }

      .situations-table,
      .situations-table tbody,
      .situations-table tr,
      .situations-table td {
        display: block;
        width: 100%;
      }

      .situations-table tr {
        padding: var(--space-md) var(--space-lg);
        border-top: 1px solid var(--border);
        background: var(--surface-elevated);
      }

      .situations-table td {
        padding: var(--space-xs) 0;
        border: none;
        width: auto;
      }

      .situations-table td:first-child {
        font-weight: 600;
        margin-bottom: var(--space-xs);
      }

      .situations-table td:last-child {
        font-size: 0.8rem;
        color: var(--text-muted);
      }

      .cta-block-btns {
        flex-direction: column;
        align-items: center;
      }
    }
  </style>

</Layout>