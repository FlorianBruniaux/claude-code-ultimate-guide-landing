---
import Layout from '../layouts/Layout.astro'
import HeroBanner from '../components/landing/HeroBanner.astro'
import PersonaRouting from '../components/landing/PersonaRouting.astro'
import Onboarding from '../components/landing/Onboarding.astro'
import ClaudeEcosystem from '../components/landing/ClaudeEcosystem.astro'

import FeaturesGrid from '../components/landing/FeaturesGrid.astro'
import WhitepapersPreview from '../components/landing/WhitepapersPreview.astro'
import McpDemo from '../components/landing/McpDemo.astro'
import GoldenRules from '../components/landing/GoldenRules.astro'
import VisualDiagrams from '../components/landing/VisualDiagrams.astro'
import SecurityTeaser from '../components/landing/SecurityTeaser.astro'
import MemorySystems from '../components/landing/MemorySystems.astro'
import ComparisonTable from '../components/landing/ComparisonTable.astro'
import Community from '../components/landing/Community.astro'
import RelatedProjects from '../components/landing/RelatedProjects.astro'

const title = 'Claude Code Guide: Templates, Security, Workflows | Free'
const description = 'Master Claude Code with 25K+ lines of documentation, 275 templates, 401-question quiz, 83 CVEs tracked, and TDD/SDD/BDD workflows. Free & open-source.'

const jsonLd = [
  {
    "@type": "Course",
    "name": "Claude Code Ultimate Guide",
    "description": "Free, open-source guide for Claude Code (Anthropic CLI): 25K+ lines of documentation, 275 templates, 401-question quiz, security threat database (83 CVEs), and methodology workflows.",
    "url": "https://cc.bruniaux.com/",
    "provider": {
      "@type": "Organization",
      "@id": "https://cc.bruniaux.com/#organization",
      "name": "Claude Code Ultimate Guide",
      "url": "https://cc.bruniaux.com",
    },
    "author": {
      "@type": "Person",
      "@id": "https://cc.bruniaux.com/#author",
      "name": "Florian BRUNIAUX",
      "url": "https://github.com/FlorianBruniaux",
      "jobTitle": "Founding Engineer",
    },
    "isAccessibleForFree": true,
    "educationalLevel": "Beginner to Advanced",
    "inLanguage": "en",
    "datePublished": "2025-06-01",
    "dateModified": "2026-06-19",
    "teaches": [
      "Claude Code CLI installation and configuration",
      "CLAUDE.md project memory files",
      "MCP server integration and security vetting",
      "Custom agents, skills, and slash commands",
      "Event hooks for automation",
      "TDD, SDD, BDD methodologies with AI",
      "Context window management",
      "Production security hardening"
    ],
    "numberOfCredits": 0,
    "hasCourseInstance": {
      "@type": "CourseInstance",
      "courseMode": "online",
      "courseWorkload": "PT10H",
    },
  },
  {
    "@type": "SoftwareApplication",
    "name": "Claude Code",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "macOS, Linux, Windows",
    "url": "https://docs.anthropic.com/en/docs/claude-code/overview",
    "description": "Anthropic's official CLI for AI-assisted development. Reads your codebase, writes code, runs commands, and makes multi-file changes autonomously from the terminal.",
    "author": {
      "@type": "Organization",
      "name": "Anthropic",
      "url": "https://anthropic.com",
    },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD",
      "description": "Free to install (API usage billed separately)",
    },
    "featureList": [
      "Full filesystem access for multi-file edits",
      "MCP server integration",
      "Custom agents, skills, and slash commands",
      "Event hooks for automation",
      "Plan Mode for complex task orchestration",
      "CLAUDE.md project memory",
    ],
  },
]
---

<Layout title={title} description={description} jsonLd={jsonLd} preloadImages={['/claude-logo-orange.svg']}>
  <HeroBanner />
  <PersonaRouting />
  <Onboarding />
  <ClaudeEcosystem />

  <FeaturesGrid />
  <WhitepapersPreview />
  <McpDemo />
  <GoldenRules />
  <VisualDiagrams />
  <SecurityTeaser />
  <MemorySystems />
  <ComparisonTable />
  <Community />
  <RelatedProjects />
</Layout>
