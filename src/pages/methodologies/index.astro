---
import Layout from '../../layouts/Layout.astro'
import MethodologyQuiz from '../../components/landing/MethodologyQuiz.astro'
import { STACK_EXPLANATIONS } from '../../data/methodology-quiz'

const title = 'AI-Assisted Development Methodologies 2026 | Claude Code Guide'
const description = '20 methodologies for AI-assisted development — TDD, BDD, BMAD, SDD, Eval-Driven, CDD and more. Quiz to find your stack. Combination patterns and decision matrix for every team size and workflow.'

const jsonLd = [
  {
    "@type": "Article",
    "headline": "AI-Assisted Development Methodologies: 20 Approaches Mapped",
    "description": "Comprehensive map of AI-assisted development methodologies with combination patterns, decision matrix, and interactive quiz to find your ideal stack.",
    "url": "https://cc.bruniaux.com/methodologies/",
    "mainEntityOfPage": "https://cc.bruniaux.com/methodologies/",
    "author": { "@type": "Person", "name": "Florian BRUNIAUX" },
    "publisher": { "@type": "Organization", "name": "Claude Code Ultimate Guide" },
    "datePublished": "2026-04-01",
    "dateModified": "2026-04-01",
    "inLanguage": "en",
    "audience": {
      "@type": "Audience",
      "audienceType": "Software developers using AI coding assistants"
    },
    "keywords": "AI development methodology, TDD, BDD, BMAD, SDD, eval-driven development, contract-driven development, plan-first, claude code methodology"
  }
]

const guideBase = 'https://cc.bruniaux.com/guide/methodologies/'

// Combination patterns table data
const COMBINATION_PATTERNS = [
  {
    stack: 'Solo MVP Builder',
    icon: '🚀',
    methodologies: 'SDD + TDD',
    bestFor: 'Solo, greenfield, quality-first',
    setup: 'Minimal',
    teamSize: '1',
    guideLink: `${guideBase}#combination-patterns`,
  },
  {
    stack: 'Team Greenfield',
    icon: '🏗️',
    methodologies: 'Spec Kit + TDD + BDD',
    bestFor: '5–10 devs, new project, shared understanding',
    setup: 'Moderate',
    teamSize: '2–10',
    guideLink: `${guideBase}#combination-patterns`,
  },
  {
    stack: 'API Contract Stack',
    icon: '🔗',
    methodologies: 'CDD + Specmatic + TDD',
    bestFor: 'Microservices, parallel teams, explicit contracts',
    setup: 'Moderate',
    teamSize: '5–20',
    guideLink: `${guideBase}#sdd-tools-reference`,
  },
  {
    stack: 'Existing Product Evolution',
    icon: '🔄',
    methodologies: 'OpenSpec + BDD + JiTTesting',
    bestFor: 'Brownfield SaaS, 100+ features, no regressions',
    setup: 'Moderate',
    teamSize: '3–15',
    guideLink: `${guideBase}#combination-patterns`,
  },
  {
    stack: 'Enterprise Governance',
    icon: '🏛️',
    methodologies: 'BMAD + Spec Kit + Specmatic',
    bestFor: 'High-complexity projects, stable requirements, compliance',
    setup: 'Heavy',
    teamSize: 'Any',
    guideLink: `${guideBase}#combination-patterns`,
  },
  {
    stack: 'AI Product Builder',
    icon: '🤖',
    methodologies: 'Eval-Driven + Multi-Agent',
    bestFor: 'Product exposes AI to users, non-deterministic outputs',
    setup: 'Moderate',
    teamSize: '1–10',
    guideLink: `${guideBase}#the-15-methodologies`,
  },
  {
    stack: 'Power User Loop',
    icon: '⚡',
    methodologies: 'TDD + Ralph Loop + Iterative Loops',
    bestFor: 'Solo, long sessions, autonomous iteration',
    setup: 'Minimal',
    teamSize: '1',
    guideLink: `${guideBase}#the-15-methodologies`,
  },
  {
    stack: 'Structured Planner',
    icon: '📋',
    methodologies: 'Plan-First + SDD + Context Engineering',
    bestFor: 'Architecture-minded, medium codebase, mixed teams',
    setup: 'Light',
    teamSize: '1–5',
    guideLink: `${guideBase}#the-15-methodologies`,
  },
]
---

<Layout title={title} description={description} ogType="article" jsonLd={jsonLd}>

  <!-- Hero -->
  <header class="page-hero">
    <div class="container">
      <div class="hero-badge-row">
        <span class="hero-badge">20 methodologies mapped</span>
        <span class="hero-badge hero-badge--secondary">8 recommended stacks</span>
      </div>
      <h1>Which Development Methodology Fits Your Workflow?</h1>
      <p class="tagline">AI-assisted development doesn't mean using Claude the same way for every project. Different team sizes, maturity levels, and contexts need different approaches.</p>
      <div class="cta-buttons">
        <a href="#methodology-quiz" class="btn btn-primary">Find My Stack →</a>
        <a href={guideBase} class="btn btn-secondary">Full Guide</a>
      </div>
    </div>
  </header>

  <!-- Methodology Quiz -->
  <MethodologyQuiz />

  <!-- Two-axis explanation -->
  <section class="section section--alt" id="methodology-map">
    <div class="container">
      <h2 class="section-title">The Two-Axis Map</h2>
      <p class="section-subtitle">Every methodology sits somewhere on two axes. Knowing where you need to be narrows the field fast.</p>
      <div class="axis-grid">
        <div class="axis-card">
          <div class="axis-icon">📐</div>
          <h3>Spec-First vs Code-First</h3>
          <p>Spec-first methodologies (BMAD, SDD, BDD) require documentation before any code runs. Code-first methods (Ralph Loop, Iterative, TDD) let you start immediately and discover structure as you build.</p>
        </div>
        <div class="axis-card">
          <div class="axis-icon">⚖️</div>
          <h3>Lean vs Enterprise</h3>
          <p>Lean methodologies minimize ceremony — one file, fast iteration, low coordination cost. Enterprise methods add traceability, multi-agent gates, and contract enforcement suited for high-complexity or compliance-driven projects.</p>
        </div>
      </div>

      <!-- ASCII map -->
      <div class="map-container" id="methodology-map-diagram">
        <p class="map-label">Positioning map (20 methodologies)</p>
        <pre class="methodology-map"><code>                      SPEC / PLANNING FIRST
                                ▲
  ── lean · spec ──             │             ── governed · spec ──
                                │
  [Doc-Driven]  [SDD]           │    [BDD]  [ATDD]   [Req-Driven]
  [GSD]  [Plan-First]           │ [CDD] [ADR-Driven]  [DDD]  [BMAD]
                                │
  LEAN ─────────────────────────┼────────────────────────────────► ENTERPRISE
                                │
  ── lean · code ──             │             ── governed · code ──
                                │
  [Context Eng.]   [TDD]        │       [Multi-Agent]
  [Prompt Eng.]  [Iterative]    │       [Eval-Driven]       [FDD]
  [Ralph Loop]                  │           [JiTTesting]
                                │
                         CODE / EMERGENT</code></pre>
        <p class="map-note">Full guide section with quadrant analysis: <a href={guideBase}>cc.bruniaux.com/guide/methodologies/</a></p>
      </div>
    </div>
  </section>

  <!-- Combination patterns table (noscript fallback + reference) -->
  <section class="section" id="methodology-decision-matrix">
    <div class="container">
      <h2 class="section-title">8 Recommended Stacks</h2>
      <p class="section-subtitle">Individual methodologies don't work in isolation. These stacks combine 2–3 methods that reinforce each other.</p>

      <div class="stacks-grid" id="methodology-stacks">
        {STACK_EXPLANATIONS.map((stack) => (
          <div class="stack-card" id={stack.stackId}>
            <div class="stack-card-header">
              <span class="stack-icon">{stack.icon}</span>
              <h3 class="stack-title">{stack.title}</h3>
            </div>
            <div class="stack-pills">
              {stack.methodologies.map((m) => (
                <span class="stack-pill">{m}</span>
              ))}
            </div>
            <p class="stack-description">{stack.description}</p>
            <div class="stack-quickstart">
              <p class="stack-quickstart-label">Quick start</p>
              <p class="stack-quickstart-text">{stack.quickStart}</p>
            </div>
            <a href={stack.guideLink} class="stack-link">Read in guide →</a>
          </div>
        ))}
      </div>

      <!-- Decision matrix table (noscript / reference) -->
      <div class="matrix-wrap" id="combination-patterns">
        <h3 class="matrix-title">At a glance</h3>
        <div class="table-scroll">
          <table class="matrix-table">
            <thead>
              <tr>
                <th>Stack</th>
                <th>Methodologies</th>
                <th>Best for</th>
                <th>Setup</th>
                <th>Team size</th>
              </tr>
            </thead>
            <tbody>
              {COMBINATION_PATTERNS.map((row) => (
                <tr>
                  <td>
                    <span class="table-icon">{row.icon}</span>
                    <a href={row.guideLink} class="table-link">{row.stack}</a>
                  </td>
                  <td><code>{row.methodologies}</code></td>
                  <td>{row.bestFor}</td>
                  <td><span class={`setup-badge setup-badge--${row.setup.toLowerCase()}`}>{row.setup}</span></td>
                  <td>{row.teamSize}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA to full guide -->
  <section class="section section--alt cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Want the full picture?</h2>
        <p>The guide covers all 20 methodologies in depth, with setup instructions, CLAUDE.md templates, combination patterns, and tradeoff analysis.</p>
        <div class="cta-buttons">
          <a href={guideBase} class="btn btn-primary">Read the Methodology Guide →</a>
          <a href="#methodology-quiz" class="btn btn-secondary">Retake the Quiz</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ── Page Hero ──────────────────────────────────────────────────────── */
.page-hero {
  padding: var(--space-3xl) 0 var(--space-2xl);
  text-align: center;
  background: var(--bg-primary);
  border-bottom: 1px solid var(--border);
}

.hero-badge-row {
  display: flex;
  gap: var(--space-sm);
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: var(--space-lg);
}

.hero-badge {
  display: inline-block;
  padding: 0.25rem 0.75rem;
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 0.8rem;
  font-family: var(--font-mono);
  color: var(--accent);
  font-weight: 500;
}

.hero-badge--secondary {
  color: var(--text-secondary);
}

.page-hero h1 {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: var(--space-lg);
  max-width: 700px;
  margin-inline: auto;
}

.tagline {
  font-size: 1.1rem;
  color: var(--text-secondary);
  line-height: 1.6;
  max-width: 560px;
  margin: 0 auto var(--space-xl);
}

.cta-buttons {
  display: flex;
  gap: var(--space-md);
  justify-content: center;
  flex-wrap: wrap;
}

/* ── Two-axis grid ──────────────────────────────────────────────────── */
.axis-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
  margin-bottom: var(--space-2xl);
}

.axis-card {
  padding: var(--space-xl);
  background: var(--surface-elevated);
  border: 1px solid var(--border);
  border-radius: var(--border-radius);
}

.axis-icon {
  font-size: 1.75rem;
  margin-bottom: var(--space-md);
}

.axis-card h3 {
  font-size: 1.05rem;
  font-weight: 700;
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.axis-card p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ── ASCII map ──────────────────────────────────────────────────────── */
.map-container {
  margin-top: var(--space-xl);
}

.map-label {
  font-size: 0.8rem;
  font-family: var(--font-mono);
  color: var(--text-secondary);
  margin-bottom: var(--space-sm);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.methodology-map {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--border-radius);
  padding: var(--space-xl);
  overflow-x: auto;
  font-family: var(--font-mono);
  font-size: 0.82rem;
  line-height: 1.6;
  color: var(--text-secondary);
}

.methodology-map code {
  font-family: inherit;
  background: none;
  color: inherit;
}

.map-note {
  font-size: 0.8rem;
  color: var(--text-secondary);
  margin-top: var(--space-sm);
}

.map-note a {
  color: var(--accent);
}

/* ── Stacks grid ────────────────────────────────────────────────────── */
.stacks-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: var(--space-lg);
  margin-bottom: var(--space-2xl);
}

.stack-card {
  padding: var(--space-xl);
  background: var(--surface-elevated);
  border: 1px solid var(--border);
  border-radius: var(--border-radius);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.stack-card-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: 0.25rem;
}

.stack-icon {
  font-size: 1.5rem;
  line-height: 1;
}

.stack-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-primary);
}

.stack-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
}

.stack-pill {
  display: inline-block;
  padding: 0.2rem 0.6rem;
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
  border-radius: 4px;
  font-size: 0.75rem;
  font-family: var(--font-mono);
  font-weight: 500;
  color: var(--accent);
}

.stack-description {
  font-size: 0.875rem;
  color: var(--text-secondary);
  line-height: 1.6;
  flex: 1;
}

.stack-quickstart {
  padding: var(--space-sm) var(--space-md);
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: 6px;
}

.stack-quickstart-label {
  font-size: 0.65rem;
  font-weight: 700;
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--accent);
  margin-bottom: 0.2rem;
}

.stack-quickstart-text {
  font-size: 0.8rem;
  color: var(--text-secondary);
  line-height: 1.5;
  font-family: var(--font-mono);
}

.stack-link {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--accent);
  text-decoration: none;
  margin-top: auto;
}

.stack-link:hover {
  text-decoration: underline;
}

/* ── Decision matrix table ──────────────────────────────────────────── */
.matrix-wrap {
  border-top: 1px solid var(--border);
  padding-top: var(--space-xl);
}

.matrix-title {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-lg);
}

.table-scroll {
  overflow-x: auto;
  border: 1px solid var(--border);
  border-radius: var(--border-radius);
}

.matrix-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
}

.matrix-table th {
  padding: var(--space-sm) var(--space-md);
  background: var(--bg-tertiary);
  border-bottom: 1px solid var(--border);
  text-align: left;
  font-weight: 600;
  color: var(--text-secondary);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-family: var(--font-mono);
  white-space: nowrap;
}

.matrix-table td {
  padding: var(--space-sm) var(--space-md);
  border-bottom: 1px solid var(--border);
  color: var(--text-primary);
  vertical-align: top;
}

.matrix-table tr:last-child td {
  border-bottom: none;
}

.matrix-table code {
  font-size: 0.8rem;
  color: var(--accent);
  background: var(--bg-tertiary);
  padding: 0.15rem 0.4rem;
  border-radius: 3px;
}

.table-icon {
  margin-right: 0.375rem;
}

.table-link {
  color: var(--text-primary);
  text-decoration: none;
  font-weight: 500;
}

.table-link:hover {
  color: var(--accent);
}

.setup-badge {
  display: inline-block;
  font-size: 0.72rem;
  font-family: var(--font-mono);
  padding: 0.15rem 0.45rem;
  border-radius: 4px;
  font-weight: 600;
}

.setup-badge--minimal {
  background: color-mix(in srgb, #22c55e 12%, transparent);
  color: #22c55e;
  border: 1px solid color-mix(in srgb, #22c55e 25%, transparent);
}

.setup-badge--light {
  background: color-mix(in srgb, var(--accent) 12%, transparent);
  color: var(--accent);
  border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
}

.setup-badge--moderate {
  background: color-mix(in srgb, #f59e0b 12%, transparent);
  color: #f59e0b;
  border: 1px solid color-mix(in srgb, #f59e0b 25%, transparent);
}

.setup-badge--heavy {
  background: color-mix(in srgb, #ef4444 12%, transparent);
  color: #ef4444;
  border: 1px solid color-mix(in srgb, #ef4444 25%, transparent);
}

/* ── CTA section ────────────────────────────────────────────────────── */
.cta-section {
  padding: var(--space-3xl) 0;
}

.cta-box {
  text-align: center;
  max-width: 560px;
  margin: 0 auto;
}

.cta-box h2 {
  font-size: 1.75rem;
  font-weight: 700;
  margin-bottom: var(--space-md);
}

.cta-box p {
  color: var(--text-secondary);
  font-size: 1rem;
  line-height: 1.6;
  margin-bottom: var(--space-xl);
}

/* ── Responsive ─────────────────────────────────────────────────────── */
@media (max-width: 640px) {
  .page-hero h1 {
    font-size: 1.6rem;
  }

  .stacks-grid {
    grid-template-columns: 1fr;
  }

  .cta-buttons {
    flex-direction: column;
  }

  .cta-buttons .btn {
    width: 100%;
    text-align: center;
  }
}
</style>
