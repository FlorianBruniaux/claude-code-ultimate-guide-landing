  .form-success { background: color-mix(in srgb, #22c55e 12%, transparent); color: #15803d; }
  .form-error { background: color-mix(in srgb, #ef4444 12%, transparent); color: #dc2626; }
  .form-error a { color: inherit; text-decoration: underline; }
  .submit-spinner { font-family: monospace; letter-spacing: 0.2em; }

  /* Paths */
