</style>

<script>
  // Restore saved contact details into a form (name / email / linkedin)
  function prefillContactFields(form: Element) {
    try {
      const name = localStorage.getItem('cc-contact-name')
      const email = localStorage.getItem('cc-contact-email')
      const linkedin = localStorage.getItem('cc-contact-linkedin')
      if (name) (form.querySelector('[name="firstname"]') as HTMLInputElement).value = name
      if (email) (form.querySelector('[name="email"]') as HTMLInputElement).value = email
      if (linkedin) (form.querySelector('[name="linkedin"]') as HTMLInputElement).value = linkedin
    } catch {}
  }

  // Toggle inline form
  document.querySelectorAll<HTMLButtonElement>('.get-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const wpNum = btn.dataset.wp
      const form = document.getElementById(`form-${wpNum}`)
      if (!form) return
      const isOpen = btn.getAttribute('aria-expanded') === 'true'
      btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true')
      form.classList.toggle('hidden', isOpen)
      if (!isOpen) {
        prefillContactFields(form)
        // Focus first empty text input
        const nameInput = form.querySelector<HTMLInputElement>('[name="firstname"]')
        const firstEmpty = form.querySelector<HTMLInputElement>('input:not(.honeypot):not([type="radio"])[value=""]')
        ;(nameInput?.value ? form.querySelector<HTMLInputElement>('[name="email"]') : nameInput)?.focus()
      }
    })
  })

  const PDF_BASE = import.meta.env.PUBLIC_PDF_BASE ?? 'https://florian.bruniaux.com/guides'

  // Capture UTM params from URL once (shared across all forms)
  const urlParams = new URLSearchParams(window.location.search)
  const utmSource = urlParams.get('utm_source') || document.referrer || 'direct'
  const utmCampaign = urlParams.get('utm_campaign') || null

  // Handle form submission
  document.querySelectorAll<HTMLFormElement>('.subscribe-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const wpNum = form.dataset.wp
      const fileFr = form.dataset.fileFr!
      const fileEn = form.dataset.fileEn!

      const honeypot = (form.querySelector('[name="website"]') as HTMLInputElement)?.value
      if (honeypot) return  // bot detected — silent ignore

      const email = (form.querySelector('[name="email"]') as HTMLInputElement)?.value
      const firstName = (form.querySelector('[name="firstname"]') as HTMLInputElement)?.value
      const linkedin = (form.querySelector('[name="linkedin"]') as HTMLInputElement)?.value?.trim() || undefined

      // Save contact details immediately — before fetch, regardless of API outcome
      try {
        if (firstName) localStorage.setItem('cc-contact-name', firstName)
        if (email) localStorage.setItem('cc-contact-email', email)
        if (linkedin) localStorage.setItem('cc-contact-linkedin', linkedin)
      } catch {}
      const format = (form.querySelector(`[name="format-${wpNum}"]:checked`) as HTMLInputElement)?.value || 'pdf'
      const lang = (form.querySelector(`[name="lang-${wpNum}"]:checked`) as HTMLInputElement)?.value || 'en'

      // filename is a stable ID (e.g. "02-personnalisation.fr") — resolved server-side
      // by /api/guides so email links never break when PDFs are updated.
      // For EPUB requests: pass epubUrl so the API sends the EPUB link in the email.
      const isEpub = format === 'epub'
      const slugFr = fileFr.replace(/\.fr(\..*)?$/, '')
      const slugEn = fileEn.replace(/\.en(\..*)?$/, '')
      const epubUrl = lang === 'fr'
        ? `/ebooks/epub/fr/${slugFr}.epub`
        : `/ebooks/epub/en/${slugEn}.epub`
      const filename = lang === 'fr' ? fileFr : fileEn

      const submitBtn = form.querySelector<HTMLButtonElement>('.submit-btn')
      const submitText = form.querySelector('.submit-text')
      const submitSpinner = form.querySelector('.submit-spinner')
      const successMsg = form.parentElement?.querySelector('.form-success')

      if (submitBtn) submitBtn.disabled = true
      submitText?.classList.add('hidden')
      submitSpinner?.classList.remove('hidden')

      try {
        const API_URL = import.meta.env.PUBLIC_API_URL ?? 'https://www.florian.bruniaux.com/api/subscribe'
        const SITE_URL = import.meta.env.PUBLIC_SITE_URL ?? 'https://cc.bruniaux.com'
        const res = await fetch(API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            firstName,
            filename,
            website: '',
            source: utmSource,
            ...(utmCampaign && { utmCampaign }),
            ...(linkedin && { linkedin }),
            ...(isEpub && { epubUrl: `${SITE_URL}${epubUrl}` }),
          }),
        })

        if (!res.ok) throw new Error(`API ${res.status}`)

        form.classList.add('hidden')
        successMsg?.classList.remove('hidden')
        // Mark as subscriber — unlocks recap cards automatically
        try { localStorage.setItem('cc-subscriber', '1') } catch {}
        // GA event
        if (typeof window.gtag === 'function') {
          window.gtag('event', 'ebook_subscribe', {
            guide: filename,
            format: isEpub ? 'epub' : 'pdf',
            source: utmSource,
            ...(utmCampaign && { campaign: utmCampaign }),
          })
        }
      } catch (err) {
        form.classList.add('hidden')
        const errorMsg = form.parentElement?.querySelector('.form-error')
        errorMsg?.classList.remove('hidden')
        console.warn('Subscribe API error:', err)
      } finally {
        if (submitBtn) submitBtn.disabled = false
        submitText?.classList.remove('hidden')
        submitSpinner?.classList.add('hidden')
      }
    })
  })
</script>
