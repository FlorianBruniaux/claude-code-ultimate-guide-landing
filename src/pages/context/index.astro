</style>

<script>
  // ── Data ────────────────────────────────────────────────────────────────
  const MATURITY_LEVELS = [
    {
      level: 1,
      name: 'Starter',
      color: '#6b7280',
      criteria: ['Single CLAUDE.md', 'No rules files or @imports', 'Basic or no structure'],
      nextSteps: ['Add project overview section', 'Add anti-patterns section', 'Add git conventions'],
    },
    {
      level: 2,
      name: 'Modular',
      color: '#3b82f6',
      criteria: ['Rules extracted to separate files', 'Path-scoping with @imports', 'Organized sections'],
      nextSteps: ['Set up path-scoped rules', 'Add CI drift detection', 'Create rules/ directory'],
    },
    {
      level: 3,
      name: 'Team-Ready',
      color: '#f59e0b',
      criteria: ['Profile-based assembly for team members', 'CI drift detection running', 'Shared module library'],
      nextSteps: ['Add self-evaluation questions', 'Set up canary checks', 'Track adherence metrics'],
    },
    {
      level: 4,
      name: 'Measured',
      color: '#10b981',
      criteria: ['Self-evaluation runs quarterly', 'Canary checks in CI', 'Adherence tracked per rule'],
      nextSteps: ['Implement knowledge feeding loop', 'Add session retrospectives', 'Build ACE pipeline'],
    },
    {
      level: 5,
      name: 'Adaptive',
      color: 'var(--accent)',
      criteria: ['Knowledge feeding loop active', 'ACE pipeline (Assemble, Check, Execute)', 'Automated context feedback'],
      nextSteps: ['Maintain and evolve', 'Share patterns with team', 'Open-source your context system'],
    },
  ]

  // ── State ───────────────────────────────────────────────────────────────
  const answers = {
    teamSize: '',
    aiTools: [] as string[],
    claudeMdStatus: '',
    rulesFiles: '',
    stack: '',
    frontend: '',
  }

  // ── Helpers ─────────────────────────────────────────────────────────────
  function showScreen(id: string) {
    document.querySelectorAll('.cc-screen').forEach((el) => el.classList.remove('cc-active'))
    const target = document.getElementById(id)
    if (target) target.classList.add('cc-active')
    window.scrollTo({ top: document.getElementById('cc-configurator')?.offsetTop ?? 0, behavior: 'smooth' })
  }

  function saveToStorage() {
    try {
      localStorage.setItem('cc-configurator-answers', JSON.stringify(answers))
    } catch (_) {}
  }

  function loadFromStorage() {
    try {
      const stored = localStorage.getItem('cc-configurator-answers')
      if (stored) {
        const parsed = JSON.parse(stored)
        Object.assign(answers, parsed)
      }
    } catch (_) {}
  }

  // ── Option selection ─────────────────────────────────────────────────────
  function initOptionGroup(groupId: string, field: string, multi = false) {
    const container = document.getElementById(groupId)
    if (!container) return

    container.querySelectorAll('.cc-option').forEach((btn) => {
      btn.addEventListener('click', () => {
        const value = (btn as HTMLElement).dataset.value || ''
        if (multi) {
          const idx = (answers as any)[field].indexOf(value)
          if (idx >= 0) {
            (answers as any)[field].splice(idx, 1)
            btn.classList.remove('cc-selected')
          } else {
            (answers as any)[field].push(value)
            btn.classList.add('cc-selected')
          }
        } else {
          container.querySelectorAll('.cc-option').forEach((b) => b.classList.remove('cc-selected'))
          btn.classList.add('cc-selected')
          ;(answers as any)[field] = value
        }
        saveToStorage()
        updateNavButtons()
      })
    })
  }

  function restoreSelections() {
    // Restore radio selections
    const radioGroups: { groupId: string; field: string }[] = [
      { groupId: 'cc-team-options', field: 'teamSize' },
      { groupId: 'cc-claude-md-options', field: 'claudeMdStatus' },
      { groupId: 'cc-rules-options', field: 'rulesFiles' },
      { groupId: 'cc-stack-options', field: 'stack' },
      { groupId: 'cc-frontend-options', field: 'frontend' },
    ]
    radioGroups.forEach(({ groupId, field }) => {
      const container = document.getElementById(groupId)
      if (!container) return
      const val = (answers as any)[field]
      if (val) {
        container.querySelector(`[data-value="${val}"]`)?.classList.add('cc-selected')
      }
    })
    // Restore multi-select
    const toolsContainer = document.getElementById('cc-tools-options')
    if (toolsContainer && answers.aiTools.length) {
      answers.aiTools.forEach((v) => {
        toolsContainer.querySelector(`[data-value="${v}"]`)?.classList.add('cc-selected')
      })
    }
  }

  function updateNavButtons() {
    const nextProfile = document.getElementById('cc-next-profile') as HTMLButtonElement | null
    const nextCurrent = document.getElementById('cc-next-current') as HTMLButtonElement | null
    const generate = document.getElementById('cc-generate') as HTMLButtonElement | null

    if (nextProfile) nextProfile.disabled = !answers.teamSize
    if (nextCurrent) nextCurrent.disabled = !answers.claudeMdStatus || !answers.rulesFiles
    if (generate) generate.disabled = !answers.stack || !answers.frontend
  }

  // ── Maturity calculation ──────────────────────────────────────────────────
  function calculateMaturity(): number {
    const { claudeMdStatus, rulesFiles, teamSize } = answers
    if (claudeMdStatus === 'none') return 1
    if (claudeMdStatus === 'small' && rulesFiles === '0') return 1
    if (rulesFiles === '0') return claudeMdStatus === 'medium' ? 2 : 1
    if (rulesFiles === '1-5') return 2
    if (rulesFiles === '6-15') return teamSize !== 'solo' ? 3 : 2
    if (rulesFiles === '15+') return teamSize !== 'solo' ? 3 : 2
    return 1
  }

  // ── Template generation ─────────────────────────────────────────────────
  function generateClaudeMd(): string {
    const { stack, frontend, teamSize } = answers
    const hasFrontend = frontend !== 'none'
    const isTeam = teamSize !== 'solo'

    const stackSections: Record<string, string> = {
      typescript: `## TypeScript Standards
- Strict mode enabled (\`strict: true\` in tsconfig.json)
- Explicit return types on all exported functions
- No \`any\` types except in migration code (must be commented)
- Prefer \`interface\` over \`type\` for object shapes
- Imports: absolute paths only (no \`../../\` chains)`,
      python: `## Python Standards
- Type hints required on all function signatures
- Docstrings for public functions (Google style)
- Use \`ruff\` for linting, \`black\` for formatting
- Prefer \`pathlib\` over \`os.path\`
- f-strings only (no \`%\` or \`.format()\`)`,
      rust: `## Rust Standards
- \`clippy\` must pass with no warnings
- \`unwrap()\` only in tests — use \`?/anyhow\` in production
- Prefer \`thiserror\` for library errors, \`anyhow\` for apps
- All public items must have doc comments
- \`async\`: use \`tokio\` as the async runtime`,
      go: `## Go Standards
- Standard library preferred over third-party when feasible
- Error wrapping: \`fmt.Errorf("context: %w", err)\`
- All exported symbols must have doc comments
- Prefer \`context.Context\` as first parameter
- No global mutable state`,
      java: `## Java/Kotlin Standards
- Prefer Kotlin over Java for new code
- Use constructor injection (not field injection)
- All public APIs must be nullable-annotated
- Sealed classes for result types
- Tests: JUnit 5, Mockito`,
      other: `## Code Standards
- Consistent naming conventions (document your conventions here)
- Error handling: explicit, never swallow exceptions silently
- Comments: explain why, not what`,
    }

    const frontendSections: Record<string, string> = {
      react: `\n## React / Frontend
- Functional components only (no class components)
- Custom hooks for shared stateful logic
- Props: TypeScript interfaces, required unless explicitly optional
- State management: prefer local state, context for shared, zustand/jotai for global
- CSS: [your preferred approach — e.g., Tailwind, CSS Modules]`,
      vue: `\n## Vue / Frontend
- Composition API only (no Options API for new code)
- TypeScript: \`defineProps\` and \`defineEmits\` with explicit types
- Composables for shared logic
- Prefer \`<script setup>\` syntax`,
      angular: `\n## Angular / Frontend
- Standalone components (no NgModule for new code)
- Signals for reactive state
- OnPush change detection for performance-sensitive components
- Inject function over constructor injection`,
      other: `\n## Frontend Standards
- [Document your frontend framework conventions here]`,
    }

    const teamSection = isTeam
      ? `\n## Team Conventions
- Branch naming: \`feat/description\`, \`fix/description\`, \`chore/description\`
- PR requirements: description of changes + test coverage
- Code review: at least 1 approval before merge
- Commit style: conventional commits (\`feat:\`, \`fix:\`, \`chore:\`)`
      : `\n## Workflow
- Commit style: conventional commits (\`feat:\`, \`fix:\`, \`chore:\`)
- Branch naming: \`feat/description\`, \`fix/description\``

    const stackSection = stackSections[stack] || stackSections.other
    const frontendSection = hasFrontend && frontendSections[frontend] ? frontendSections[frontend] : ''

    return `# CLAUDE.md — [Project Name]
<!-- Generated by cc.bruniaux.com/context/ — customize for your project -->

## Project Overview
<!-- Required: 2-3 sentences describing what this project does and who uses it -->
[Describe your project here]

## Architecture
<!-- Document key architectural decisions -->
- Stack: ${stack}${hasFrontend ? ` + ${frontend}` : ''}
- [Add your key architecture decisions here]
- [Database, state management, deployment target]

${stackSection}
${frontendSection}
## Testing
- Tests required for: all new features, bug fixes, critical paths
- Test files co-located with source: \`component.test.ts\` next to \`component.ts\`
- Mock strategy: mock at the boundary (external APIs, databases)
${teamSection}

## What NOT to Do
<!-- Anti-patterns specific to your project — add your own -->
- Do not add dependencies without discussing trade-offs first
- Do not use \`console.log\` in production code (use structured logging)
- Do not commit secrets or API keys (use environment variables)
- Do not skip tests for "simple" changes

## Deployment
<!-- Document your deployment process -->
- Environments: [staging → production]
- Deploy command: \`[your deploy command]\`
- Post-deploy: [what to verify after deployment]
`
  }

  function generateProfileYaml(): string | null {
    const { teamSize, stack, frontend } = answers
    if (teamSize === 'solo') return null

    const role = stack === 'typescript' && frontend !== 'none'
      ? 'frontend'
      : frontend === 'none'
      ? 'backend'
      : 'fullstack'

    return `# Team Profile Template
# Save as: .claude/profiles/<team-member-name>.yaml
# Run: ts-node assembler.ts --profile .claude/profiles/<name>.yaml

profile:
  name: "developer-name"
  role: "${role}"
  seniority: "mid"  # junior | mid | senior | staff

tools:
  primary_lang: "${stack}"
  frontend: "${frontend}"

modules:
  include:
    - shared/core-rules.md
    - shared/git-conventions.md
    - shared/security-rules.md
    # Add role-specific modules as you create them

overrides:
  custom_rules: []
  # Add personal preferences here
`
  }

  // ── Results rendering ────────────────────────────────────────────────────
  function renderResults() {
    const level = calculateMaturity()
    const maturityData = MATURITY_LEVELS[level - 1]

    // Badge and name
    const badge = document.getElementById('cc-maturity-badge')
    const nameEl = document.getElementById('cc-maturity-name')
    if (badge) {
      badge.textContent = `L${level}`
      badge.style.setProperty('--maturity-color', maturityData.color)
      badge.style.background = maturityData.color === 'var(--accent)' ? 'var(--accent)' : maturityData.color
    }
    if (nameEl) nameEl.textContent = `Level ${level} — ${maturityData.name}`

    // Level pips
    const card = document.getElementById('cc-maturity-display')
    if (card) {
      card.style.setProperty('--maturity-color', maturityData.color === 'var(--accent)' ? 'var(--accent)' : maturityData.color)
      card.querySelectorAll('.cc-level-pip').forEach((pip) => {
        const pipLevel = parseInt((pip as HTMLElement).dataset.level || '0')
        if (pipLevel <= level) {
          pip.classList.add('cc-pip-active')
          ;(pip as HTMLElement).style.background = maturityData.color === 'var(--accent)' ? 'var(--accent)' : maturityData.color
        } else {
          pip.classList.remove('cc-pip-active')
          ;(pip as HTMLElement).style.background = ''
        }
      })
    }

    // Criteria and next steps
    const criteriaEl = document.getElementById('cc-maturity-criteria')
    const nextEl = document.getElementById('cc-maturity-next')
    if (criteriaEl) {
      criteriaEl.innerHTML = maturityData.criteria.map((c) => `<li>${c}</li>`).join('')
    }
    if (nextEl) {
      if (level === 5) {
        nextEl.innerHTML = maturityData.nextSteps.map((s) => `<li>${s}</li>`).join('')
      } else {
        const nextLevel = MATURITY_LEVELS[level]
        nextEl.innerHTML = nextLevel.nextSteps.map((s) => `<li>${s}</li>`).join('')
      }
    }

    // CLAUDE.md artifact
    const claudeMdEl = document.getElementById('cc-claude-md-content')
    if (claudeMdEl) claudeMdEl.textContent = generateClaudeMd()

    // Profile YAML
    const profileSection = document.getElementById('cc-profile-yaml-section')
    const profileEl = document.getElementById('cc-profile-yaml-content')
    const profileYaml = generateProfileYaml()
    if (profileSection && profileEl) {
      if (profileYaml) {
        profileSection.style.display = ''
        profileEl.textContent = profileYaml
      } else {
        profileSection.style.display = 'none'
      }
    }
  }

  // ── Copy to clipboard ────────────────────────────────────────────────────
  function initCopyButtons() {
    document.querySelectorAll('.cc-copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const targetId = (btn as HTMLElement).dataset.target
        if (!targetId) return
        const source = document.getElementById(targetId)
        if (!source) return
        const text = source.textContent || ''
        try {
          await navigator.clipboard.writeText(text)
        } catch (_) {
          // Fallback for older browsers
          const ta = document.createElement('textarea')
          ta.value = text
          ta.style.position = 'fixed'
          ta.style.opacity = '0'
          document.body.appendChild(ta)
          ta.select()
          document.execCommand('copy')
          document.body.removeChild(ta)
        }
        btn.textContent = 'Copied!'
        btn.classList.add('cc-copied')
        setTimeout(() => {
          btn.textContent = 'Copy'
          btn.classList.remove('cc-copied')
        }, 2000)
      })
    })
  }

  // ── Wire navigation ─────────────────────────────────────────────────────
  function initNav() {
    document.getElementById('cc-start')?.addEventListener('click', () => showScreen('cc-step-profile'))

    document.getElementById('cc-next-profile')?.addEventListener('click', () => {
      saveToStorage()
      showScreen('cc-step-current')
    })

    document.getElementById('cc-back-current')?.addEventListener('click', () => showScreen('cc-step-profile'))
    document.getElementById('cc-next-current')?.addEventListener('click', () => {
      saveToStorage()
      showScreen('cc-step-stack')
    })

    document.getElementById('cc-back-stack')?.addEventListener('click', () => showScreen('cc-step-current'))
    document.getElementById('cc-generate')?.addEventListener('click', () => {
      saveToStorage()
      renderResults()
      showScreen('cc-results')
    })

    document.getElementById('cc-restart')?.addEventListener('click', () => {
      // Reset state
      answers.teamSize = ''
      answers.aiTools = []
      answers.claudeMdStatus = ''
      answers.rulesFiles = ''
      answers.stack = ''
      answers.frontend = ''
      document.querySelectorAll('.cc-option.cc-selected').forEach((el) => el.classList.remove('cc-selected'))
      updateNavButtons()
      try { localStorage.removeItem('cc-configurator-answers') } catch (_) {}
      showScreen('cc-intro')
    })
  }

  // ── Init ────────────────────────────────────────────────────────────────
  function init() {
    loadFromStorage()
    restoreSelections()
    updateNavButtons()

    initOptionGroup('cc-team-options', 'teamSize', false)
    initOptionGroup('cc-tools-options', 'aiTools', true)
    initOptionGroup('cc-claude-md-options', 'claudeMdStatus', false)
    initOptionGroup('cc-rules-options', 'rulesFiles', false)
    initOptionGroup('cc-stack-options', 'stack', false)
    initOptionGroup('cc-frontend-options', 'frontend', false)

    initNav()
    initCopyButtons()
  }

  init()
</script>
