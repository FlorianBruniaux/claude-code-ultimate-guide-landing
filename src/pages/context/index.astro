---
import Layout from '../../layouts/Layout.astro'

const title = 'Context Engineering Configurator | Claude Code Guide'
const description = 'Generate a personalized CLAUDE.md starter kit in 3 steps. Answer questions about your team size, current setup, and tech stack — get a ready-to-use context file plus a maturity level assessment.'

const jsonLd = [
  {
    "@type": "WebApplication",
    "name": "Context Engineering Configurator",
    "description": "Multi-step configurator that generates a personalized CLAUDE.md starter kit based on team size, current context setup, and tech stack",
    "url": "https://cc.bruniaux.com/context/",
    "applicationCategory": "DeveloperApplication",
    "author": { "@type": "Person", "name": "Florian BRUNIAUX" },
    "publisher": { "@type": "Organization", "name": "Claude Code Ultimate Guide" },
    "inLanguage": "en",
  }
]
---

<Layout title={title} description={description} ogType="article" jsonLd={jsonLd}>

  <!-- Hero -->
  <header class="page-hero">
    <div class="container">
      <div class="cc-badge-row">
        <span class="cc-hero-badge">3 steps · under 2 minutes · no sign-up</span>
        <span class="cc-hero-badge cc-hero-badge--secondary">Generates CLAUDE.md + maturity score</span>
      </div>
      <h1>Build Your AI Context System</h1>
      <p class="tagline">Answer 3 short questions and get a personalized CLAUDE.md starter kit, a maturity level assessment, and concrete next steps.</p>
      <div class="cta-buttons">
        <a href="#cc-configurator" class="btn btn-primary">Start Configurator →</a>
        <a href="https://cc.bruniaux.com/guide/context-engineering/" class="btn btn-secondary">Read the Guide</a>
      </div>
    </div>
  </header>

  <!-- Configurator -->
  <section class="section cc-section" id="cc-configurator" aria-label="Context engineering configurator">
    <div class="container">
      <div class="cc-wrapper">

        <!-- Screen: Intro -->
        <div id="cc-intro" class="cc-screen cc-active">
          <div class="cc-intro-content">
            <div class="cc-intro-badge">Configure Your Context</div>
            <h2 class="cc-intro-title">Generate Your Starter Kit</h2>
            <p class="cc-intro-sub">
              Tell us about your team size, what you already have set up, and your tech stack. We will generate a ready-to-use CLAUDE.md and score your context maturity level.
            </p>
            <div class="cc-intro-features">
              <div class="cc-intro-feature">
                <span class="cc-feature-icon">📄</span>
                <span>Personalized CLAUDE.md</span>
              </div>
              <div class="cc-intro-feature">
                <span class="cc-feature-icon">📊</span>
                <span>Maturity level 1–5</span>
              </div>
              <div class="cc-intro-feature">
                <span class="cc-feature-icon">🎯</span>
                <span>Concrete next steps</span>
              </div>
              <div class="cc-intro-feature">
                <span class="cc-feature-icon">👥</span>
                <span>Team profile template</span>
              </div>
            </div>
            <button id="cc-start" class="btn btn-primary cc-start-btn">Start Configurator →</button>
            <noscript>
              <p class="cc-noscript">JavaScript is required for the configurator. <a href="https://cc.bruniaux.com/guide/context-engineering/">Read the Context Engineering guide instead →</a></p>
            </noscript>
          </div>
        </div>

        <!-- Screen: Step 1 — Profile -->
        <div id="cc-step-profile" class="cc-screen">
          <div class="cc-progress-bar">
            <div class="cc-progress-fill" style="width: 33%"></div>
          </div>
          <div class="cc-step-meta">
            <span class="cc-step-num">Step 1 of 3</span>
            <span class="cc-step-label">Your Profile</span>
          </div>

          <div class="cc-field-group">
            <h3 class="cc-field-title">Team size</h3>
            <p class="cc-field-sub">How many developers work on this project?</p>
            <div class="cc-options-grid" id="cc-team-options" role="group" aria-label="Team size">
              <button class="cc-option" data-group="teamSize" data-value="solo">
                <span class="cc-option-label">Solo</span>
                <span class="cc-option-desc">Just me</span>
              </button>
              <button class="cc-option" data-group="teamSize" data-value="small">
                <span class="cc-option-label">2-5 people</span>
                <span class="cc-option-desc">Small team</span>
              </button>
              <button class="cc-option" data-group="teamSize" data-value="medium">
                <span class="cc-option-label">6-20 people</span>
                <span class="cc-option-desc">Medium team</span>
              </button>
              <button class="cc-option" data-group="teamSize" data-value="large">
                <span class="cc-option-label">20+</span>
                <span class="cc-option-desc">Large team</span>
              </button>
            </div>
          </div>

          <div class="cc-field-group">
            <h3 class="cc-field-title">AI tools you use <span class="cc-optional">(select all that apply)</span></h3>
            <p class="cc-field-sub">Which AI coding tools are active in your workflow?</p>
            <div class="cc-options-grid cc-options-grid--multi" id="cc-tools-options" role="group" aria-label="AI tools">
              <button class="cc-option cc-option--check" data-group="aiTools" data-value="claude-code">
                <span class="cc-option-label">Claude Code</span>
                <span class="cc-option-desc">CLI tool (CLAUDE.md)</span>
              </button>
              <button class="cc-option cc-option--check" data-group="aiTools" data-value="cursor">
                <span class="cc-option-label">Cursor</span>
                <span class="cc-option-desc">.cursorrules</span>
              </button>
              <button class="cc-option cc-option--check" data-group="aiTools" data-value="copilot">
                <span class="cc-option-label">GitHub Copilot</span>
                <span class="cc-option-desc">.github/copilot-instructions.md</span>
              </button>
              <button class="cc-option cc-option--check" data-group="aiTools" data-value="windsurf">
                <span class="cc-option-label">Windsurf</span>
                <span class="cc-option-desc">.windsurfrules</span>
              </button>
              <button class="cc-option cc-option--check" data-group="aiTools" data-value="codex">
                <span class="cc-option-label">OpenAI Codex</span>
                <span class="cc-option-desc">AGENTS.md</span>
              </button>
            </div>
          </div>

          <div class="cc-nav">
            <div></div>
            <button id="cc-next-profile" class="btn btn-primary cc-nav-btn" disabled>Next →</button>
          </div>
        </div>

        <!-- Screen: Step 2 — Current Setup -->
        <div id="cc-step-current" class="cc-screen">
          <div class="cc-progress-bar">
            <div class="cc-progress-fill" style="width: 66%"></div>
          </div>
          <div class="cc-step-meta">
            <span class="cc-step-num">Step 2 of 3</span>
            <span class="cc-step-label">Current Setup</span>
          </div>

          <div class="cc-field-group">
            <h3 class="cc-field-title">Your CLAUDE.md status</h3>
            <p class="cc-field-sub">How developed is your current context file?</p>
            <div class="cc-options-grid" id="cc-claude-md-options" role="group" aria-label="CLAUDE.md status">
              <button class="cc-option" data-group="claudeMdStatus" data-value="none">
                <span class="cc-option-label">No CLAUDE.md yet</span>
                <span class="cc-option-desc">Starting from scratch</span>
              </button>
              <button class="cc-option" data-group="claudeMdStatus" data-value="small">
                <span class="cc-option-label">Under 100 lines</span>
                <span class="cc-option-desc">Basic setup</span>
              </button>
              <button class="cc-option" data-group="claudeMdStatus" data-value="medium">
                <span class="cc-option-label">100-500 lines</span>
                <span class="cc-option-desc">Established setup</span>
              </button>
              <button class="cc-option" data-group="claudeMdStatus" data-value="large">
                <span class="cc-option-label">500+ lines</span>
                <span class="cc-option-desc">Comprehensive setup</span>
              </button>
            </div>
          </div>

          <div class="cc-field-group">
            <h3 class="cc-field-title">Separate rules files</h3>
            <p class="cc-field-sub">How many .md files in your rules/ or .claude/ directories?</p>
            <div class="cc-options-grid" id="cc-rules-options" role="group" aria-label="Rules files count">
              <button class="cc-option" data-group="rulesFiles" data-value="0">
                <span class="cc-option-label">None</span>
                <span class="cc-option-desc">No separate rules files</span>
              </button>
              <button class="cc-option" data-group="rulesFiles" data-value="1-5">
                <span class="cc-option-label">1-5 files</span>
                <span class="cc-option-desc">Some modularization</span>
              </button>
              <button class="cc-option" data-group="rulesFiles" data-value="6-15">
                <span class="cc-option-label">6-15 files</span>
                <span class="cc-option-desc">Well-modularized</span>
              </button>
              <button class="cc-option" data-group="rulesFiles" data-value="15+">
                <span class="cc-option-label">15+ files</span>
                <span class="cc-option-desc">Fully modular</span>
              </button>
            </div>
          </div>

          <div class="cc-nav">
            <button id="cc-back-current" class="btn btn-secondary cc-nav-btn">← Back</button>
            <button id="cc-next-current" class="btn btn-primary cc-nav-btn" disabled>Next →</button>
          </div>
        </div>

        <!-- Screen: Step 3 — Stack -->
        <div id="cc-step-stack" class="cc-screen">
          <div class="cc-progress-bar">
            <div class="cc-progress-fill" style="width: 100%"></div>
          </div>
          <div class="cc-step-meta">
            <span class="cc-step-num">Step 3 of 3</span>
            <span class="cc-step-label">Tech Stack</span>
          </div>

          <div class="cc-field-group">
            <h3 class="cc-field-title">Primary language</h3>
            <p class="cc-field-sub">What is the main backend or system language?</p>
            <div class="cc-options-grid" id="cc-stack-options" role="group" aria-label="Primary stack">
              <button class="cc-option" data-group="stack" data-value="typescript">
                <span class="cc-option-label">TypeScript / Node</span>
                <span class="cc-option-desc">TS, Node, npm/pnpm</span>
              </button>
              <button class="cc-option" data-group="stack" data-value="python">
                <span class="cc-option-label">Python</span>
                <span class="cc-option-desc">FastAPI, Django, Flask</span>
              </button>
              <button class="cc-option" data-group="stack" data-value="rust">
                <span class="cc-option-label">Rust</span>
                <span class="cc-option-desc">Cargo, async/tokio</span>
              </button>
              <button class="cc-option" data-group="stack" data-value="go">
                <span class="cc-option-label">Go</span>
                <span class="cc-option-desc">Standard library, gin, echo</span>
              </button>
              <button class="cc-option" data-group="stack" data-value="java">
                <span class="cc-option-label">Java / Kotlin</span>
                <span class="cc-option-desc">Spring, JVM</span>
              </button>
              <button class="cc-option" data-group="stack" data-value="other">
                <span class="cc-option-label">Other</span>
                <span class="cc-option-desc">PHP, Ruby, C++, etc.</span>
              </button>
            </div>
          </div>

          <div class="cc-field-group">
            <h3 class="cc-field-title">Frontend framework</h3>
            <p class="cc-field-sub">Any frontend layer on this project?</p>
            <div class="cc-options-grid" id="cc-frontend-options" role="group" aria-label="Frontend framework">
              <button class="cc-option" data-group="frontend" data-value="react">
                <span class="cc-option-label">React</span>
                <span class="cc-option-desc">React / Next.js / Vite</span>
              </button>
              <button class="cc-option" data-group="frontend" data-value="vue">
                <span class="cc-option-label">Vue</span>
                <span class="cc-option-desc">Vue / Nuxt</span>
              </button>
              <button class="cc-option" data-group="frontend" data-value="angular">
                <span class="cc-option-label">Angular</span>
                <span class="cc-option-desc">Angular / NgRx</span>
              </button>
              <button class="cc-option" data-group="frontend" data-value="none">
                <span class="cc-option-label">No frontend</span>
                <span class="cc-option-desc">Backend only, CLI, API</span>
              </button>
              <button class="cc-option" data-group="frontend" data-value="other">
                <span class="cc-option-label">Other</span>
                <span class="cc-option-desc">Svelte, Astro, etc.</span>
              </button>
            </div>
          </div>

          <div class="cc-nav">
            <button id="cc-back-stack" class="btn btn-secondary cc-nav-btn">← Back</button>
            <button id="cc-generate" class="btn btn-primary cc-nav-btn" disabled>Generate Kit →</button>
          </div>
        </div>

        <!-- Screen: Results -->
        <div id="cc-results" class="cc-screen">
          <div class="cc-results-header">
            <h2 class="cc-results-title">Your Starter Kit</h2>
            <button id="cc-restart" class="cc-restart-btn">Start Over</button>
          </div>

          <!-- Maturity level -->
          <div class="cc-maturity-card" id="cc-maturity-display">
            <div class="cc-maturity-header">
              <div>
                <p class="cc-section-label">Context Maturity</p>
                <h3 id="cc-maturity-name" class="cc-maturity-name">Level 1 — Starter</h3>
              </div>
              <div id="cc-maturity-badge" class="cc-maturity-badge">L1</div>
            </div>
            <div class="cc-maturity-levels">
              <div class="cc-level-pip" data-level="1"></div>
              <div class="cc-level-pip" data-level="2"></div>
              <div class="cc-level-pip" data-level="3"></div>
              <div class="cc-level-pip" data-level="4"></div>
              <div class="cc-level-pip" data-level="5"></div>
            </div>
            <div class="cc-maturity-cols">
              <div>
                <p class="cc-maturity-col-label">Current criteria</p>
                <ul id="cc-maturity-criteria" class="cc-maturity-list"></ul>
              </div>
              <div>
                <p class="cc-maturity-col-label">Next steps to level up</p>
                <ul id="cc-maturity-next" class="cc-maturity-list cc-maturity-list--next"></ul>
              </div>
            </div>
          </div>

          <!-- CLAUDE.md artifact -->
          <div class="cc-artifact">
            <div class="cc-artifact-header">
              <div class="cc-artifact-title-row">
                <span class="cc-artifact-filename">CLAUDE.md</span>
                <span class="cc-artifact-badge">Personalized</span>
              </div>
              <button class="cc-copy-btn" id="cc-copy-claude-md" data-target="cc-claude-md-content">Copy</button>
            </div>
            <pre id="cc-claude-md-content" class="cc-artifact-body"></pre>
          </div>

          <!-- Profile YAML (team only) -->
          <div class="cc-artifact" id="cc-profile-yaml-section" style="display: none">
            <div class="cc-artifact-header">
              <div class="cc-artifact-title-row">
                <span class="cc-artifact-filename">.claude/profiles/developer.yaml</span>
                <span class="cc-artifact-badge cc-artifact-badge--secondary">Team profiles</span>
              </div>
              <button class="cc-copy-btn" id="cc-copy-profile" data-target="cc-profile-yaml-content">Copy</button>
            </div>
            <pre id="cc-profile-yaml-content" class="cc-artifact-body"></pre>
          </div>

          <!-- Links -->
          <div class="cc-results-links">
            <a href="https://cc.bruniaux.com/guide/context-engineering/" class="cc-result-link">Read the Context Engineering guide →</a>
            <a href="https://github.com/FlorianBruniaux/claude-code-ultimate-guide/tree/main/examples/context-engineering" class="cc-result-link">Browse example templates on GitHub →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- What is Context Engineering -->
  <section class="section section--alt">
    <div class="container">
      <h2 class="section-title">What Is Context Engineering?</h2>
      <p class="section-subtitle">The practice of systematically designing and managing the information you give AI coding tools — so they produce better output, more reliably.</p>
      <div class="cc-concepts-grid">
        <div class="cc-concept-card">
          <div class="cc-concept-icon">📄</div>
          <h3>CLAUDE.md as a contract</h3>
          <p>The CLAUDE.md file tells Claude Code what your project is, how it is structured, and what the team's conventions are. It is read at the start of every session, so it shapes every response.</p>
        </div>
        <div class="cc-concept-card">
          <div class="cc-concept-icon">🗂️</div>
          <h3>Modular rules files</h3>
          <p>Instead of one giant file, experienced teams extract rules into separate .md files — one per concern (security, testing, git) — and import them via @path syntax. Easier to maintain, easier to scope by directory.</p>
        </div>
        <div class="cc-concept-card">
          <div class="cc-concept-icon">👤</div>
          <h3>Profile-based assembly</h3>
          <p>On larger teams, different roles need different context. A profile YAML defines which modules to assemble for a given team member — frontend dev, backend dev, or staff engineer.</p>
        </div>
        <div class="cc-concept-card">
          <div class="cc-concept-icon">🔄</div>
          <h3>The ACE pipeline</h3>
          <p>Assemble, Check, Execute. The most mature setups automate context assembly from modules, run drift detection in CI to catch stale rules, and feed session learnings back into the context system.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Maturity ladder overview -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">The 5 Maturity Levels</h2>
      <p class="section-subtitle">Where most teams start and where the best teams end up.</p>
      <div class="cc-ladder">
        <div class="cc-ladder-item">
          <div class="cc-ladder-level" style="--level-color: #6b7280">L1</div>
          <div class="cc-ladder-content">
            <h3>Starter</h3>
            <p>Single CLAUDE.md, written once, rarely updated. Better than nothing, but drift accumulates fast.</p>
          </div>
        </div>
        <div class="cc-ladder-item">
          <div class="cc-ladder-level" style="--level-color: #3b82f6">L2</div>
          <div class="cc-ladder-content">
            <h3>Modular</h3>
            <p>Rules extracted to separate files, organized by concern. @imports keep the root file clean. Path-scoping directs rules to the right subdirectories.</p>
          </div>
        </div>
        <div class="cc-ladder-item">
          <div class="cc-ladder-level" style="--level-color: #f59e0b">L3</div>
          <div class="cc-ladder-content">
            <h3>Team-Ready</h3>
            <p>Profile-based assembly for different roles. Shared module library across the team. CI drift detection flags when docs fall out of sync with the codebase.</p>
          </div>
        </div>
        <div class="cc-ladder-item">
          <div class="cc-ladder-level" style="--level-color: #10b981">L4</div>
          <div class="cc-ladder-content">
            <h3>Measured</h3>
            <p>Quarterly self-evaluations test whether Claude follows the rules. Canary checks in CI verify rule adherence. Metrics per rule, not just per project.</p>
          </div>
        </div>
        <div class="cc-ladder-item">
          <div class="cc-ladder-level" style="--level-color: var(--accent)">L5</div>
          <div class="cc-ladder-content">
            <h3>Adaptive</h3>
            <p>Knowledge feeding loop: every session retrospective updates the context. ACE pipeline runs automatically. The context system improves itself over time.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cc-cta-section">
    <div class="container">
      <div class="cc-cta-box">
        <h2>Full guide in the docs</h2>
        <p>The Context Engineering section covers every maturity level in depth — architecture patterns, example file structures, CI setup, and real team configurations.</p>
        <div class="cta-buttons">
          <a href="https://cc.bruniaux.com/guide/context-engineering/" class="btn btn-primary">Read the Full Guide →</a>
          <a href="/" class="btn btn-secondary">← Back to Home</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ============================================
   Hero badges
   ============================================ */
.cc-badge-row {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}

.cc-hero-badge {
  display: inline-block;
  padding: 0.25rem 0.75rem;
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 0.8rem;
  font-family: var(--font-mono);
  color: var(--accent);
  font-weight: 500;
}

.cc-hero-badge--secondary {
  color: var(--text-secondary);
}

/* ============================================
   Configurator section
   ============================================ */
.cc-section {
  background: var(--bg-secondary);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.cc-wrapper {
  max-width: 680px;
  margin: 0 auto;
}

/* Screen visibility */
.cc-screen {
  display: none;
}

.cc-screen.cc-active {
  display: block;
}

/* ============================================
   Intro screen
   ============================================ */
.cc-intro-content {
  text-align: center;
  padding: var(--space-xl) 0;
}

.cc-intro-badge {
  display: inline-block;
  padding: 0.25rem 0.75rem;
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 0.8rem;
  font-family: var(--font-mono);
  color: var(--accent);
  font-weight: 500;
  margin-bottom: var(--space-lg);
}

.cc-intro-title {
  font-size: 1.75rem;
  font-weight: 700;
  margin-bottom: var(--space-md);
  color: var(--text-primary);
}

.cc-intro-sub {
  color: var(--text-secondary);
  font-size: 1rem;
  line-height: 1.6;
  max-width: 480px;
  margin: 0 auto var(--space-xl);
}

.cc-intro-features {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  justify-content: center;
  margin-bottom: var(--space-xl);
}

.cc-intro-feature {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.375rem 0.75rem;
  background: var(--surface-elevated);
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.cc-feature-icon {
  font-size: 1rem;
}

.cc-start-btn {
  font-size: 1rem;
  padding: 0.875rem 2.5rem;
  min-width: 200px;
}

.cc-noscript {
  margin-top: var(--space-md);
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.cc-noscript a {
  color: var(--accent);
}

/* ============================================
   Progress bar
   ============================================ */
.cc-progress-bar {
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: var(--space-xl);
}

.cc-progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 2px;
  transition: width 0.3s ease;
}

/* ============================================
   Step meta
   ============================================ */
.cc-step-meta {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}

.cc-step-num {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--text-secondary);
  font-weight: 600;
}

.cc-step-label {
  font-size: 0.75rem;
  padding: 0.2rem 0.6rem;
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
