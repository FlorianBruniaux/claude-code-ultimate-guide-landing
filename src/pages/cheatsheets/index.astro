---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { RECAP_SERIES, RECAP_BASE_URL, CARD_HASHES_FR, CARD_HASHES_EN, DIRECT_ACCESS_IDS } from '../../data/recap-cards-data'

const allCards = await getCollection('cheatsheets')
const allSorted = allCards.sort((a, b) => a.data.order - b.data.order)

const techniqueCards = allSorted.filter(c => c.data.category === 'Technical')
const methodologieCards = allSorted.filter(c => c.data.category === 'Methodology')
const conceptionCards = allSorted.filter(c => c.data.category === 'Design')

// All series released (T + M + C)
const cards = allSorted
const totalCards = cards.length

const difficultyLabel: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
}

const title = `Cheat Sheets — ${allSorted.length} Recap Cards | Claude Code`
const description = `${allSorted.length} printable A4 recap cards covering Claude Code commands, workflows, agents, MCP, security, and more. Plus the original 1-page quick reference.`

const jsonLd = [
  {
    "@type": "ItemList",
    "name": "Claude Code Cheat Sheets",
    "description": description,
    "numberOfItems": allSorted.length + 1,
    "url": "https://cc.bruniaux.com/cheatsheets/",
    "itemListElement": allSorted.map((card, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://cc.bruniaux.com/cheatsheets/${card.id}/`,
      "name": card.data.title,
    })),
  }
]

// API base URL for subscribe endpoint (overridable via env for local dev)
const API_BASE = (import.meta.env.PUBLIC_API_URL ?? 'https://www.florian.bruniaux.com/api/subscribe').replace('/api/subscribe', '')

// Build card URL maps for client-side JS (card id → full hashed URL)
const cardUrlsFr: Record<string, string> = {}
const cardUrlsEn: Record<string, string> = {}
for (const card of cards) {
  const hashFr = CARD_HASHES_FR[card.id]
  if (hashFr) cardUrlsFr[card.id] = `${RECAP_BASE_URL}/${hashFr}`
  const hashEn = CARD_HASHES_EN[card.id]
  if (hashEn) cardUrlsEn[card.id] = `${RECAP_BASE_URL}/${hashEn}`
}
// Legacy alias used in gate form (FR ZIPs)
const cardUrls = cardUrlsFr
---

<Layout title={title} description={description} jsonLd={jsonLd}>

  <header class="page-hero">
    <div class="container">
      <h1>Cheat Sheets</h1>
      <p class="tagline">{totalCards} printable A4 recap cards — commands, workflows, agents, security, MCP, and more.</p>
      <div class="cta-buttons">
        <a href="#cards" class="btn btn-primary">Browse all cards</a>
        <a href="/cheatsheet/" class="btn btn-secondary">Quick Reference (1-page EN)</a>
      </div>
    </div>
  </header>

  <section class="content-section" id="cards">
    <div class="container">

      <!-- Stats row -->
      <div class="stats-row">
        <div class="stat-item">
          <span class="stat-number">{allSorted.length}</span>
          <span class="stat-label">Recap Cards</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">{techniqueCards.length}</span>
          <span class="stat-label">Technical</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">{methodologieCards.length}</span>
          <span class="stat-label">Methodology</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">{conceptionCards.length}</span>
          <span class="stat-label">Design</span>
        </div>
      </div>

      <!-- Original cheatsheet card + Whitepapers cross-promo -->
      <div class="featured-row">
        <a href="/cheatsheet/" class="featured-card">
          <div class="featured-badge">1-PAGE QUICK REF</div>
          <div class="featured-content">
            <h3>Quick Reference</h3>
            <p>All essential commands, shortcuts, hooks, MCP, and golden rules on a single printable page. English.</p>
          </div>
          <svg class="featured-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/whitepapers/" class="featured-card">
          <div class="featured-badge">11 EBOOKS</div>
          <div class="featured-content">
            <h3>Deep-dive Whitepapers</h3>
            <p>472+ pages, FR + EN, PDF + EPUB. Architecture, security, team adoption, ROI, and more.</p>
          </div>
          <svg class="featured-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Filter tabs -->
      <div class="filter-tabs" role="tablist" aria-label="Filter by category">
        <button class="tab-btn active" data-filter="all" role="tab" aria-selected="true">
          All <span class="tab-count">{totalCards}</span>
        </button>
        <button class="tab-btn" data-filter="Technical" data-series="T" role="tab" aria-selected="false">
          Technical <span class="tab-count">{techniqueCards.length}</span>
        </button>
        <button class="tab-btn" data-filter="Methodology" data-series="M" role="tab" aria-selected="false">
          Methodology <span class="tab-count">{methodologieCards.length}</span>
        </button>
        <button class="tab-btn" data-filter="Design" data-series="C" role="tab" aria-selected="false">
          Design <span class="tab-count">{conceptionCards.length}</span>
        </button>
      </div>

      <!-- Gate banner (rendered server-side, shown/hidden by client JS) -->
      <div class="gate-banner hidden" id="gate-banner" aria-live="polite">
        <div class="gate-icon">🔒</div>
        <div class="gate-text">
          <p class="gate-title" id="gate-title">Get the full Technical series — PDF bundle delivered to your inbox</p>
          <p class="gate-sub">Enter your email to get the full series as a PDF bundle delivered to your inbox.</p>
        </div>
        <form class="gate-form" id="gate-form" novalidate>
          <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true">
          <input type="text" name="firstname" id="gate-firstname" placeholder="Full name (optional)" autocomplete="name" maxlength="100">
          <input type="email" name="email" id="gate-email" placeholder="you@example.com" required autocomplete="email">
          <input type="url" name="linkedin" id="gate-linkedin" placeholder="LinkedIn profile (optional)" autocomplete="url" maxlength="200">
          <div class="gate-lang-selector">
            <span class="gate-lang-label">PDF:</span>
            <input type="radio" name="gate-lang" value="en" id="gate-lang-en" checked class="gate-lang-radio">
            <input type="radio" name="gate-lang" value="fr" id="gate-lang-fr" class="gate-lang-radio">
            <button type="button" class="gate-lang-btn gate-lang-btn-en gate-lang-btn--active" data-lang="en" aria-pressed="true">EN</button>
            <button type="button" class="gate-lang-btn gate-lang-btn-fr" data-lang="fr" aria-pressed="false">FR</button>
          </div>
          <button type="submit" class="gate-submit" id="gate-submit">
            <span class="submit-label">Get all cards</span>
            <span class="submit-spinner hidden" aria-hidden="true"></span>
          </button>
        </form>
        <p class="gate-error hidden" id="gate-error" role="alert"></p>
        <p class="gate-success hidden" id="gate-success" role="status"></p>
        <!-- Download state: shown when series is already unlocked -->
        <div class="gate-unlocked hidden" id="gate-unlocked">
          <div class="gate-unlocked-header">
            <p class="gate-unlocked-label" id="gate-unlocked-title">Your bundle is ready</p>
            <p class="gate-unlocked-sub" id="gate-unlocked-sub">Download your PDF bundles below</p>
          </div>
          <div class="gate-unlocked-links" id="gate-unlocked-links"></div>
          <div class="gate-unlocked-design hidden" id="gate-unlocked-design">
            <span class="gate-unlocked-divider">Also free:</span>
            <div class="gate-unlocked-design-links" id="gate-unlocked-design-links"></div>
          </div>
        </div>
      </div>

      <!-- "Coming soon" for Design series (shown by JS when C tab active) -->
      <div class="coming-soon-msg hidden" id="coming-soon-msg">
        <p>Design series (13 cards) — coming soon.</p>
        <p class="coming-soon-sub">13 cards on trust calibration, prompting, security, and architecture design.</p>
        <form id="waitlist-form" class="waitlist-form" novalidate>
          <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true">
          <div class="waitlist-row">
            <input type="email" name="email" placeholder="you@example.com" required autocomplete="email">
            <button type="submit" class="btn btn-primary btn-sm">Notify me</button>
          </div>
        </form>
        <p id="waitlist-success" class="waitlist-success hidden">You're on the list!</p>
        <p id="waitlist-error" class="waitlist-error hidden"></p>
      </div>

      <!-- Cards grid -->
      <div class="cards-grid" id="cards-grid">
        {cards.map(card => (
          <article
            class="recap-card"
            data-category={card.data.category}
            data-series={card.data.cardNumber[0]}
          >
            <a href={`/cheatsheets/${card.id}/`} class="card-link">
              <div class="card-header">
                <span class={`card-number-badge series-${card.data.cardNumber[0].toLowerCase()}`}>
                  {card.data.cardNumber}
                </span>
                <span class={`difficulty-pill diff-${card.data.difficulty}`}>
                  {difficultyLabel[card.data.difficulty]}
                </span>
                {DIRECT_ACCESS_IDS.has(card.id) ? (
                  <span class="access-badge">DIRECT ACCESS</span>
                ) : (
                  <span class="access-locked" aria-label="Email required">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M18 10V7a6 6 0 00-12 0v3H4a1 1 0 00-1 1v10a1 1 0 001 1h16a1 1 0 001-1V11a1 1 0 00-1-1h-2zm-6 7a2 2 0 110-4 2 2 0 010 4zm4-7H8V7a4 4 0 018 0v3z"/>
                    </svg>
                  </span>
                )}
              </div>
              <div class="card-body">
                <h3 class="card-title">{card.data.title}</h3>
                <p class="card-subtitle">{card.data.subtitle}</p>
              </div>
              <span class="card-read">Read →</span>
            </a>
            <div class="card-footer">
              <div class="pdf-buttons">
                {DIRECT_ACCESS_IDS.has(card.id) ? (
                  <!-- Direct access: dual FR/EN buttons -->
                  <>
                    {cardUrlsFr[card.id] && (
                      <a class="pdf-pill pdf-fr" href={cardUrlsFr[card.id]} download aria-label={`Download ${card.data.title} FR PDF`}>
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        FR
                      </a>
                    )}
                    {cardUrlsEn[card.id] && (
                      <a class="pdf-pill pdf-en" href={cardUrlsEn[card.id]} download aria-label={`Download ${card.data.title} EN PDF`}>
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        EN
                      </a>
                    )}
                  </>
                ) : (
                  <!-- Gated: upgraded by JS when unlocked -->
                  <span class="pdf-pill pdf-gated" data-card-id={card.id} data-series={card.data.cardNumber[0]} data-url-fr={cardUrlsFr[card.id] ?? ''} data-url-en={cardUrlsEn[card.id] ?? ''} role="button" tabindex="0" aria-label={`Download ${card.data.title} PDF`}>
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    PDF
                  </span>
                )}
              </div>
              <a href={`/cheatsheets/${card.id}/`} class="card-read">Read →</a>
            </div>
          </article>
        ))}
      </div>

      <p class="no-results hidden" id="no-results">No cards match this filter.</p>

    </div>
  </section>

</Layout>

<script define:vars={{ RECAP_BASE_URL, RECAP_SERIES, API_BASE, cardUrlsMapFr: cardUrlsFr, cardUrlsMapEn: cardUrlsEn }}>
// ──────────────────────────────────────────────────────────────────────────────
// Recap Cards Gating Logic
// ──────────────────────────────────────────────────────────────────────────────

const LS_SUBSCRIBER = 'cc-subscriber'
const lsUnlockKey = (s) => `cc-unlocked-${s}`

function isUnlocked(seriesId) {
  try {
    return localStorage.getItem(LS_SUBSCRIBER) === '1' ||
           localStorage.getItem(lsUnlockKey(seriesId)) === '1'
  } catch { return false }
}

function setUnlocked(seriesId) {
  try {
    localStorage.setItem(lsUnlockKey(seriesId), '1')
  } catch {}
}

// Upgrade gated PDF spans to dual FR/EN links for unlocked series
function upgradeUnlockedPDFs() {
  document.querySelectorAll('.pdf-gated').forEach(span => {
    const series = span.dataset.series
    const cardId = span.dataset.cardId
    if (!series || !isUnlocked(series)) return

    const urlFr = (span.dataset.urlFr) || cardUrlsMapFr[cardId]
    const urlEn = (span.dataset.urlEn) || cardUrlsMapEn[cardId]
    if (!urlFr && !urlEn) return

    const frag = document.createDocumentFragment()

    if (urlFr) {
      const aFr = document.createElement('a')
      aFr.href = urlFr
      aFr.className = 'pdf-pill pdf-fr'
      aFr.setAttribute('download', '')
      aFr.setAttribute('aria-label', `Download FR PDF`)
      aFr.innerHTML = span.innerHTML.replace('PDF', 'FR')
      frag.appendChild(aFr)
    }
    if (urlEn) {
      const aEn = document.createElement('a')
      aEn.href = urlEn
      aEn.className = 'pdf-pill pdf-en'
      aEn.setAttribute('download', '')
      aEn.setAttribute('aria-label', `Download EN PDF`)
      aEn.innerHTML = span.innerHTML.replace('PDF', 'EN')
      frag.appendChild(aEn)
    }

    span.parentNode.replaceChild(frag, span)
  })
}

// Gate banner state
let activeSeries = null  // 'T' | 'M' | 'C' | null (null = "All" tab)

const gateBanner = document.getElementById('gate-banner')
const gateTitle  = document.getElementById('gate-title')
const gateForm   = document.getElementById('gate-form')
const gateEmail  = document.getElementById('gate-email')
const gateFirstname = document.getElementById('gate-firstname')

// Pre-fill contact fields from a previous submission
try {
  const savedName = localStorage.getItem('cc-contact-name')
  const savedEmail = localStorage.getItem('cc-contact-email')
  const savedLinkedin = localStorage.getItem('cc-contact-linkedin')
  if (savedName && gateFirstname) gateFirstname.value = savedName
  if (savedEmail && gateEmail) gateEmail.value = savedEmail
  if (savedLinkedin) {
    const liInput = document.getElementById('gate-linkedin')
    if (liInput) liInput.value = savedLinkedin
  }
} catch {}
const gateSubmit = document.getElementById('gate-submit')
const gateError  = document.getElementById('gate-error')
const gateSuccess = document.getElementById('gate-success')
const comingSoon = document.getElementById('coming-soon-msg')

function seriesData(id) {
  return RECAP_SERIES.find(s => s.id === id)
}

function showUnlockedBanner(seriesIds) {
  const gateUnlocked = document.getElementById('gate-unlocked')
  const gateUnlockedLinks = document.getElementById('gate-unlocked-links')
  const gateUnlockedTitle = document.getElementById('gate-unlocked-title')
  const gateUnlockedSub = document.getElementById('gate-unlocked-sub')
  const gateUnlockedDesign = document.getElementById('gate-unlocked-design')
  const gateUnlockedDesignLinks = document.getElementById('gate-unlocked-design-links')
  const gateIcon = gateBanner.querySelector('.gate-icon')
  const gateTextEl = gateBanner.querySelector('.gate-text')

  if (!gateUnlocked || !gateUnlockedLinks) return

  // Switch icon to green checkmark
  if (gateIcon) {
    gateIcon.textContent = '✓'
    gateIcon.classList.add('gate-icon--unlocked')
  }

  // Hide the locked text (title + subtitle)
  if (gateTextEl) gateTextEl.classList.add('hidden')

  // Update unlocked header text
  const names = seriesIds.map(function(id) { return seriesData(id) ? seriesData(id).name : null }).filter(Boolean)
  if (gateUnlockedTitle) {
    gateUnlockedTitle.textContent = names.length > 1
      ? names.join(' + ') + ' series unlocked'
      : names[0] + ' series unlocked'
  }
  if (gateUnlockedSub) {
    gateUnlockedSub.textContent = 'Download your PDF bundles below'
  }

  // Populate ZIP download buttons
  gateUnlockedLinks.innerHTML = ''
  for (var i = 0; i < seriesIds.length; i++) {
    var sid = seriesIds[i]
    var s = seriesData(sid)
    if (!s) continue
    if (s.hashedZipFr) {
      var aFr = document.createElement('a')
      aFr.href = RECAP_BASE_URL + '/' + s.hashedZipFr
      aFr.className = 'zip-dl-btn'
      aFr.setAttribute('download', '')
      aFr.setAttribute('aria-label', 'Download ' + s.name + ' FR PDF bundle')
      aFr.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round"/></svg>' + s.name + ' FR'
      gateUnlockedLinks.appendChild(aFr)
    }
    if (s.hashedZipEn) {
      var aEn = document.createElement('a')
      aEn.href = RECAP_BASE_URL + '/' + s.hashedZipEn
      aEn.className = 'zip-dl-btn'
      aEn.setAttribute('download', '')
      aEn.setAttribute('aria-label', 'Download ' + s.name + ' EN PDF bundle')
      aEn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round"/></svg>' + s.name + ' EN'
      gateUnlockedLinks.appendChild(aEn)
    }
  }

  // Show Design free cards section (when "All" tab or Design relevant)
  if (gateUnlockedDesign && gateUnlockedDesignLinks) {
    var designCards = [
      { id: 'c01-trust-calibration', label: 'Trust Calibration' },
      { id: 'c02-prompting-basics', label: 'Prompting Basics' },
      { id: 'c03-xml-prompting-anchors', label: 'XML Anchors' },
    ]
    gateUnlockedDesignLinks.innerHTML = ''
    var hasDesignLinks = false
    for (var j = 0; j < designCards.length; j++) {
      var dc = designCards[j]
      var urlFr = cardUrlsMapFr[dc.id]
      var urlEn = cardUrlsMapEn[dc.id]
      if (!urlFr && !urlEn) continue
      hasDesignLinks = true
      var lang = urlEn ? urlEn : urlFr
      var designA = document.createElement('a')
      designA.href = urlFr || urlEn
      designA.className = 'zip-dl-btn zip-dl-btn--design'
      designA.setAttribute('download', '')
      designA.setAttribute('aria-label', 'Download ' + dc.label + ' FR PDF')
      designA.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round"/></svg>' + dc.label
      gateUnlockedDesignLinks.appendChild(designA)
    }
    if (hasDesignLinks) {
      gateUnlockedDesign.classList.remove('hidden')
    }
  }

  if (gateForm) gateForm.classList.add('hidden')
  gateUnlocked.classList.remove('hidden')
  gateBanner.classList.remove('hidden')
}

function resetBannerState() {
  const gateUnlocked = document.getElementById('gate-unlocked')
  const gateTextEl = gateBanner.querySelector('.gate-text')
  if (gateUnlocked) gateUnlocked.classList.add('hidden')
  if (gateTextEl) gateTextEl.classList.remove('hidden')
  if (gateForm) gateForm.classList.remove('hidden')
  const gateIcon = gateBanner.querySelector('.gate-icon')
  if (gateIcon) {
    gateIcon.textContent = '🔒'
    gateIcon.classList.remove('gate-icon--unlocked')
  }
}

function updateGateBanner(filter) {
  if (!gateBanner) return

  // filter: 'all' | 'Technical' | 'Methodology' | 'Design'
  const seriesMap = { 'Technical': 'T', 'Methodology': 'M', 'Design': 'C' }
  const sid = seriesMap[filter] || null
  activeSeries = sid

  // Hide coming-soon by default
  if (comingSoon) comingSoon.classList.add('hidden')

  resetBannerState()

  const series = sid ? seriesData(sid) : null

  // Specific released series (not Design — no ZIP yet)
  if (series && series.released && sid !== 'C') {
    if (!isUnlocked(sid)) {
      gateBanner.classList.remove('hidden')
      if (gateTitle) gateTitle.textContent = `Get the full ${series.name} series — PDF bundle delivered to your inbox`
      resetGateForm()
    } else {
      showUnlockedBanner([sid])
    }
    return
  }

  // "All" tab
  if (!sid) {
    const tLocked = !isUnlocked('T')
    const mLocked = !isUnlocked('M')
    if (tLocked || mLocked) {
      gateBanner.classList.remove('hidden')
      if (gateTitle) gateTitle.textContent = `Get the full PDF bundles — Technical + Methodology + Design series`
      resetGateForm()
    } else {
      showUnlockedBanner(['T', 'M', 'C'])
    }
    return
  }

  // Design or unreleased — hide banner
  gateBanner.classList.add('hidden')
}

function resetGateForm() {
  if (gateError) { gateError.classList.add('hidden'); gateError.textContent = '' }
  if (gateSuccess) { gateSuccess.classList.add('hidden'); gateSuccess.textContent = '' }
  if (gateSubmit) {
    gateSubmit.disabled = false
    gateSubmit.querySelector('.submit-label').classList.remove('hidden')
    gateSubmit.querySelector('.submit-spinner').classList.add('hidden')
  }
}

// Form submission
if (gateForm) {
  gateForm.addEventListener('submit', async (e) => {
    e.preventDefault()

    const email = gateEmail?.value?.trim()
    if (!email) {
      showError('Please enter a valid email.')
      return
    }

    // Determine which series to send (for "all" tab, send the first locked one then the other)
    const seriesesToSend = activeSeries
      ? [activeSeries].filter(s => !isUnlocked(s))
      : ['T', 'M'].filter(s => !isUnlocked(s))

    if (seriesesToSend.length === 0) {
      gateBanner.classList.add('hidden')
      upgradeUnlockedPDFs()
      return
    }

    setLoading(true)

    const firstname = gateFirstname?.value?.trim() || ''
    const linkedin = document.getElementById('gate-linkedin')?.value?.trim() || ''
    const honeypot = gateForm.querySelector('input[name="website"]')?.value || ''

    // Save contact details immediately — before fetch, regardless of API outcome
    try {
      const email_ = gateEmail?.value?.trim()
      if (firstname) localStorage.setItem('cc-contact-name', firstname)
      if (email_) localStorage.setItem('cc-contact-email', email_)
      if (linkedin) localStorage.setItem('cc-contact-linkedin', linkedin)
    } catch {}
    const utmCampaign = new URLSearchParams(location.search).get('utm_campaign') || ''
    const utmSource = new URLSearchParams(location.search).get('utm_source') || 'cheatsheets'
    const selectedLang = gateForm.querySelector('input[name="gate-lang"]:checked')?.value || 'en'

    // Send one request per ZIP that needs to be unlocked
    const errors = []
    for (const sid of seriesesToSend) {
      const series = seriesData(sid)
      const zipFile = selectedLang === 'fr' ? series?.hashedZipFr : series?.hashedZipEn
      if (!series || !zipFile) continue

      try {
        const res = await fetch(`${API_BASE}/api/subscribe`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            firstName: firstname || undefined,
            filename: zipFile,
            website: honeypot,
            source: utmSource,
            utmCampaign: utmCampaign || undefined,
            linkedin: linkedin || undefined,
          }),
        })
        const data = await res.json()
        if (data.success) {
          setUnlocked(sid)
        } else {
          errors.push(data.error || 'Request failed')
        }
      } catch {
        errors.push('Network error. Please try again.')
      }
    }

    setLoading(false)

    if (errors.length > 0) {
      showError(errors[0])
      return
    }

    // Set shared subscriber flag
    try { localStorage.setItem(LS_SUBSCRIBER, '1') } catch {}

    // Fire GA event
    try {
      if (typeof gtag !== 'undefined') {
        gtag('event', 'recap_card_subscribe', {
          event_category: 'engagement',
          event_label: seriesesToSend.join('+'),
        })
      }
    } catch {}

    showSuccess('Check your inbox — the PDF bundle is on its way!')
    upgradeUnlockedPDFs()

    // Hide banner after short delay
    setTimeout(() => {
      if (gateBanner) gateBanner.classList.add('hidden')
    }, 3000)
  })
}

function setLoading(loading) {
  if (!gateSubmit) return
  gateSubmit.disabled = loading
  gateSubmit.querySelector('.submit-label').classList.toggle('hidden', loading)
  gateSubmit.querySelector('.submit-spinner').classList.toggle('hidden', !loading)
}

function showError(msg) {
  if (gateError) { gateError.textContent = msg; gateError.classList.remove('hidden') }
  if (gateSuccess) gateSuccess.classList.add('hidden')
}

function showSuccess(msg) {
  if (gateSuccess) { gateSuccess.textContent = msg; gateSuccess.classList.remove('hidden') }
  if (gateError) gateError.classList.add('hidden')
}

// Gated PDF click: scroll to gate banner
document.addEventListener('click', (e) => {
  const target = e.target.closest('.pdf-gated')
  if (!target) return
  e.preventDefault()
  e.stopPropagation()
  if (gateBanner && !gateBanner.classList.contains('hidden')) {
    gateBanner.scrollIntoView({ behavior: 'smooth', block: 'center' })
    gateEmail?.focus()
  }
})
document.addEventListener('keydown', (e) => {
  if (e.key !== 'Enter' && e.key !== ' ') return
  const target = e.target.closest('.pdf-gated')
  if (!target) return
  e.preventDefault()
  if (gateBanner && !gateBanner.classList.contains('hidden')) {
    gateBanner.scrollIntoView({ behavior: 'smooth', block: 'center' })
    gateEmail?.focus()
  }
})

// ── Filter tabs ──────────────────────────────────────────────────────────────
const tabBtns = document.querySelectorAll('.tab-btn')
const cardItems = document.querySelectorAll('.recap-card')
const noResults = document.getElementById('no-results')
const cardsGrid = document.getElementById('cards-grid')

function filterCards(filter) {
  let visible = 0
  cardItems.forEach(card => {
    const category = card.dataset.category ?? ''
    const show = filter === 'all' || category === filter
    card.style.display = show ? '' : 'none'
    if (show) visible++
  })
  if (noResults) noResults.classList.toggle('hidden', visible > 0)

  if (cardsGrid) cardsGrid.style.display = ''
}

tabBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    tabBtns.forEach(b => {
      b.classList.remove('active')
      b.setAttribute('aria-selected', 'false')
    })
    btn.classList.add('active')
    btn.setAttribute('aria-selected', 'true')
    const filter = btn.dataset.filter ?? 'all'
    filterCards(filter)
    updateGateBanner(filter)
  })
})

// ── Lang selector buttons ────────────────────────────────────────────────────
document.querySelectorAll('.gate-lang-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const lang = btn.dataset.lang
    const radio = document.getElementById(`gate-lang-${lang}`)
    if (radio) radio.checked = true
    document.querySelectorAll('.gate-lang-btn').forEach(b => {
      b.classList.toggle('gate-lang-btn--active', b.dataset.lang === lang)
      b.setAttribute('aria-pressed', String(b.dataset.lang === lang))
    })
  })
})

// ── Init ─────────────────────────────────────────────────────────────────────
upgradeUnlockedPDFs()
updateGateBanner('all')

// ── Waitlist form (Design series) ────────────────────────────────────────────
const waitlistForm = document.getElementById('waitlist-form')
const waitlistSuccess = document.getElementById('waitlist-success')
const waitlistError = document.getElementById('waitlist-error')

const LS_WAITLIST_DESIGN = 'waitlist-design'

// Restore persisted state on load
if (waitlistSuccess && waitlistError && waitlistForm) {
  if (localStorage.getItem(LS_WAITLIST_DESIGN) === '1') {
    waitlistForm.classList.add('hidden')
    waitlistSuccess.classList.remove('hidden')
  }
}

if (waitlistForm) {
  waitlistForm.addEventListener('submit', async (e) => {
    e.preventDefault()
    const emailInput = waitlistForm.querySelector('input[type="email"]')
    const honeypot = waitlistForm.querySelector('input[name="website"]')?.value || ''
    const email = emailInput?.value?.trim()

    if (!email) {
      if (waitlistError) { waitlistError.textContent = 'Please enter a valid email.'; waitlistError.classList.remove('hidden') }
      return
    }

    const submitBtn = waitlistForm.querySelector('button[type="submit"]')
    if (submitBtn) submitBtn.disabled = true

    try {
      const res = await fetch(`${API_BASE}/api/subscribe`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          interest: 'design-series',
          website: honeypot,
          source: 'cheatsheets-waitlist',
        }),
      })
      const data = await res.json()
      if (data.success) {
        try { localStorage.setItem(LS_WAITLIST_DESIGN, '1') } catch {}
        waitlistForm.classList.add('hidden')
        if (waitlistSuccess) waitlistSuccess.classList.remove('hidden')
        if (waitlistError) waitlistError.classList.add('hidden')
      } else {
        if (waitlistError) { waitlistError.textContent = data.error || 'Something went wrong. Try again.'; waitlistError.classList.remove('hidden') }
        if (submitBtn) submitBtn.disabled = false
      }
    } catch {
      if (waitlistError) { waitlistError.textContent = 'Network error. Please try again.'; waitlistError.classList.remove('hidden') }
      if (submitBtn) submitBtn.disabled = false
    }
  })
}
</script>

